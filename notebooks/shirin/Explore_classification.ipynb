043d\\u043e \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435. \\u041d\\u043e \\u0435\\u0441\\u043b\\u0438 \\u043c\\u044b \\u043f\\u043e\\u043f\\u044b\\u0442\\u0430\\u0435\\u043c\\u0441\\u044f \\u0438\\u0437\\u0432\\u043b\\u0435\\u0447\\u044c \\u0433\\u043b\\u0430\\u0432\\u043d\\u0443\\u044e \\u043a\\u043b\\u0430\\u0443\\u0437\\u0443 \\u043a\\u0430\\u043a \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u0443, \\u0442\\u043e \\u043c\\u044b \\u0434\\u043e\\u043b\\u0436\\u043d\\u044b \\u0432\\u0437\\u044f\\u0442\\u044c \\u0442\\u0435\\u043a\\u0441\\u0442 \\u043e\\u0442 \\\"\\u042f\\\" \\u0434\\u043e \\\"\\u0445\\u043e\\u043b\\u043e\\u0434\\u043d\\u0435\\u0435\\\", \\u043d\\u043e \\u0442\\u043e\\u0433\\u0434\\u0430 \\u0432\\u043d\\u0443\\u0442\\u0440\\u044c \\u043f\\u043e\\u043f\\u0430\\u0434\\u0435\\u0442 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435. \\u042d\\u0442\\u043e \\u043d\\u0435\\u0432\\u0435\\u0440\\u043d\\u043e. \\u0417\\u043d\\u0430\\u0447\\u0438\\u0442, \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u043a\\u043b\\u0430\\u0443\\u0437\\u0430 \\u043d\\u0435 \\u044f\\u0432\\u043b\\u044f\\u0435\\u0442\\u0441\\u044f \\u043d\\u0435\\u043f\\u0440\\u0435\\u0440\\u044b\\u0432\\u043d\\u043e\\u0439.\\\\n\\\\n\\u0412\\u044b\\u0432\\u043e\\u0434: \\u0432 \\u0434\\u0430\\u043d\\u043d\\u043e\\u043c \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0438 \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u043a\\u043b\\u0430\\u0443\\u0437\\u0430 \\u0440\\u0430\\u0437\\u043e\\u0440\\u0432\\u0430\\u043d\\u0430. \\u0421\\u043e\\u0433\\u043b\\u0430\\u0441\\u043d\\u043e \\u043d\\u0435\\u043a\\u043e\\u0442\\u043e\\u0440\\u044b\\u043c \\u043f\\u043e\\u0434\\u0445\\u043e\\u0434\\u0430\\u043c, \\u0432 \\u0442\\u0430\\u043a\\u0438\\u0445 \\u0441\\u043b\\u0443\\u0447\\u0430\\u044f\\u0445 \\u0432\\u044b\\u0434\\u0435\\u043b\\u044f\\u044e\\u0442 \\u0434\\u0432\\u0435 \\u043a\\u043b\\u0430\\