        "def extract_clause_spans(text, clauses):\n",
        "    spans = []\n",
        "    search_start = 0\n",
        "\n",
        "    for i, clause in enumerate(clauses):\n",
        "        target = clause.strip()\n",
        "        if not target:\n",
        "            continue\n",
        "\n",
        "        start_idx = text.find(target, search_start)\n",
        "        used_len = len(target)\n",
        "\n",
        "        if start_idx == -1:\n",
        "            clean_target = re.sub(r'^[^\\wа-яёa-z0-9]+|[^\\wа-яёa-z0-9]+$', '', target)\n",
        "            if clean_target:\n",
        "                start_idx = text.find(clean_target, search_start)\n",
        "                used_len = len(clean_target)\n",
        "\n",
        "        if start_idx == -1:\n",
        "            break\n",
        "\n",
        "        end_idx = start_idx + used_len\n",
        "        spans.append((start_idx, end_idx, clause))\n",
        "\n",
        "        search_start = end_idx\n",
        "\n",
        "    return spans\n",
        "\n",
        "def dict_to_clause_spans(data):\n",
        "    return extract_clause_spans(data[\"text\"], data[\"clauses\"])"
      ],
