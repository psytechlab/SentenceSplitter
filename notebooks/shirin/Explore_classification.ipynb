        "import re\n",
        "import spacy\n",
        "\n",
        "def normalize_text_and_entities(text, entities):\n",
        "    doc = nlp.make_doc(text)\n",
        "\n",
        "    insertions = []\n",
        "\n",
        "    for token in doc:\n",
        "        token_text = token.text\n",
        "        start_char = token.idx\n",
        "\n",
        "        matches = re.finditer(r'([а-яА-ЯёЁa-zA-Z0-9])([!?\\.\\,\\:\\;\\(\\)\\[\\]\\{\\}\\'\\\"\\/\\\\@\\#\\$\\%\\^\\&\\*\\+\\=\\~\\`\\<\\>])', token_text)\n",
        "\n",
        "        for match in matches:\n",
        "            insert_pos = start_char + match.end(1)\n",
        "            insertions.append(insert_pos)\n",
        "\n",
        "    insertions = sorted(list(set(insertions)), reverse=True)\n",
        "\n",
        "    normalized_text = text\n",
        "    for pos in insertions:\n",
        "        normalized_text = normalized_text[:pos] + ' ' + normalized_text[pos:]\n",
        "\n",
        "    updated_entities = []\n",
        "    for start, end, label in entities:\n",
        "        shift = sum(1 for pos in insertions if pos <= start)\n",
        "        end_shift = sum(1 for pos in insertions if pos <= end)\n",
        "\n",
        "        new_start = start + shift\n",
        "        new_end = end + end_shift\n",
        "\n",
        "        updated_entities.append((new_start, new_end, label))\n",
        "\n",
        "    return normalized_text, updated_entities\n",
        "\n",
        "\n",
        "text = \"Грусть пришла давно!=(\"\n",
        "entities = [(0, 19, 'clause')]\n",
        "\n",
        "normalized_text, updated_entities = normalize_text_and_entities(text, entities)\n",
        "\n",
        "print(\"Исходный текст:\", text)\n",
        "print(\"Нормализованный текст:\", normalized_text)\n",
        "print(\"Исходные сущности:\", entities)\n",
        "print(\"Обновленные сущности:\", updated_entities)\n",
        "\n",
        "# Проверка с spaCy\n",
        "doc = spacy.load(\"ru_core_news_sm\").make_doc(normalized_text)\n",
        "from spacy.training import offsets_to_biluo_tags\n",
        "tags = offsets_to_biluo_tags(doc, updated_entities)\n",
        "print(\"Токены:\", [t.text for t in doc])\n",
        "print(\"Теги:\", tags)"
