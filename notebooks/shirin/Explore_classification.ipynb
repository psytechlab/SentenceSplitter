\u0435 \\u0441\\u043e\\u0441\\u0442\\u0430\\u0432. \\u041d\\u043e \\u0442\\u043e\\u0433\\u0434\\u0430 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435 \\u044f\\u0432\\u043b\\u044f\\u0435\\u0442\\u0441\\u044f \\u0447\\u0430\\u0441\\u0442\\u044c\\u044e \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439, \\u0438 \\u043c\\u044b \\u043d\\u0435 \\u043c\\u043e\\u0436\\u0435\\u043c \\u0432\\u044b\\u0434\\u0435\\u043b\\u0438\\u0442\\u044c \\u0435\\u0433\\u043e \\u043e\\u0442\\u0434\\u0435\\u043b\\u044c\\u043d\\u043e \\u043a\\u0430\\u043a \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u0443, \\u043d\\u0435 \\u043d\\u0430\\u0440\\u0443\\u0448\\u0430\\u044f \\u043d\\u0435\\u043f\\u0440\\u0435\\u0440\\u044b\\u0432\\u043d\\u043e\\u0441\\u0442\\u0438. \\u041e\\u0434\\u043d\\u0430\\u043a\\u043e \\u043c\\u044b \\u043c\\u043e\\u0436\\u0435\\u043c \\u0432\\u044b\\u0434\\u0435\\u043b\\u0438\\u0442\\u044c \\u0435\\u0433\\u043e \\u043a\\u0430\\u043a \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u0443 \\u0432\\u043d\\u0443\\u0442\\u0440\\u0438 \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439. \\u0422\\u043e \\u0435\\u0441\\u0442\\u044c \\u043e\\u0434\\u043d\\u0430 \\u043a\\u043b\\u0430\\u0443\\u0437\\u0430 \\u0431\\u0443\\u0434\\u0435\\u0442 \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u043e\\u0439 \\u0434\\u0440\\u0443\\u0433\\u043e\\u0439. \\u042d\\u0442\\u043e \\u0434\\u043e\\u043f\\u0443\\u0441\\u0442\\u0438\\u043c\\u043e? \\u0412 \\u0443\\u0441\\u043b\\u043e\\u0432\\u0438\\u0438 \\u043d\\u0435 \\u0441\\u043a\\u0430\\u0437\\u0430\\u043d\\u043e, \\u0447\\u0442\\u043e \\u043e\\u043d\\u0438 \\u043d\\u0435 \\u043c\\u043e\\u0433\\u0443\\u0442 \\u0431\\u044b\\u0442\\u044c \\u0432\\u043b\\u043e\\u0436\\u0435\\u043d\\u043d\\u044b\\u043c\\u0438. \\u041d\\u043e \\u0432 \\u043f\\u0440\\u0438\\u043c\\u0435\\u0440\\u0430\\u0445 \\u0442\\u0430\\u043a\\u043e\\u0433\\u043e \\u043d\\u0435\\u0442. \\u0414\\u0430\\u0432\\u0430\\u0439\\u0442\\u0435 \\u043f\\u043e\\u0441\\u043c\\u043e\\u0442\\u0440\\u0438\\u043c \\u043d\\u0430 \\u043f\\u0440\\u0438\\u043c\\u0435\\u0440 \\u0438\\u0437 \\u043f\\u0440\\u0430\\u0432\\u0438\\u043b: \\\"\\u0414\\u043e\\u0436\\u0434\\u044c \\u043a\\u043e\\u043d\\u0447\\u0438\\u043b\\u0441\\u044f, \\u0438 \\u043c\\u044b \\u0432\\u044b\\u0448\\u043b\\u0438.\\\" \\u2014 \\u0437\\u0434\\u0435\\u0441\\u044c \\u043d\\u0435\\u0442 \\u0432\\u043b\\u043e\\u0436\\u0435\\u043d\\u043d\\u043e\\u0441\\u0442\\u0438. \\u0414\\u0440\\u0443\\u0433\\u043e\\u0439 \\u043f\\u0440\\u0438\\u043c\\u0435\\u0440: \\\"\\u0421\\u043e\\u043b\\u043d\\u0446\\u0435 \\u0441\\u0435\\u043b\\u043e: \\u0441\\u0442\\u0430\\u043b\\u043e \\u043f\\u0440\\u043e\\u0445\\u043b\\u0430\\u0434\\u043d\\u043e.\\\" \\u2014 \\u0442\\u043e\\u0436\\u0435 \\u043f\\u043e\\u0441\\u043b\\u0435\\u0434\\u043e\\u0432\\u0430\\u0442\\u0435\\u043b\\u044c\\u043d\\u044b\\u0435.\\\\n\\\\n\\u0412\\u043e\\u0437\\u043c\\u043e\\u0436\\u043d\\u043e, \\u0432 \\u0434\\u0430\\u043d\\u043d\\u043e\\u043c \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0438 \\u043d\\u0435\\u0442 \\u0432\\u043b\\u043e\\u0436\\u0435\\u043d\\u043d\\u043e\\u0441\\u0442\\u0438, \\u0435\\u0441\\u043b\\u0438 \\u043c\\u044b \\u043f\\u0440\\u0430\\u0432\\u0438\\u043b\\u044c\\u043d\\u043e \\u043e\\u043f\\u0440\\u0435\\u0434\\u0435\\u043b\\u0438\\u043c \\u0441\\u0442\\u0440\\u0443\\u043a\\u0442\\u0443\\u0440\\u0443. \\u041d\\u0430\\u0448\\u0435 \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0435: \\\"\\u0412\\u0441\\u0435 \\u0443\\u0447\\u0438\\u0442\\u0435\\u043b\\u044f \\u0438 \\u0432\\u0437\\u0440\\u043e\\u0441\\u043b\\u044b\\u0435 \\u043b\\u044e\\u0434\\u0438 \\u0443\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435 \\u043c\\u0435\\u043d\\u044f \\u0437\\u043d\\u0430\\u044e\\u0442 \\u043c\\u0435\\u043d\\u044f \\u043b\\u044e\\u0431\\u044f\\u0442 \\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e, \\u0447\\u0442\\u043e \\u044f \\u0432\\u0441\\u0435\\u0433\\u0434\\u0430 \\u0438\\u043c \\u0434\\u043e\\u0431\\u0440\\u043e\\u0432\\u043e\\u043b\\u044c\\u043d\\u043e \\u043f\\u043e\\u043c\\u043e\\u0433\\u0430\\u044e \\u0438 \\u0442\\u0434.\\\" \\u0417\\u0434\\u0435\\u0441\\u044c \\\"\\u0443\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435 \\u043c\\u0435\\u043d\\u044f \\u0437\\u043d\\u0430\\u044e\\u0442\\\" \\u2014 \\u044d\\u0442\\u043e \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435 \\u043e\\u043f\\u0440\\u0435\\u0434\\u0435\\u043b\\u0438\\u0442\\u0435\\u043b\\u044c\\u043d\\u043e\\u0435, \\u043a\\u043e\\u0442\\u043e\\u0440\\u043e\\u0435 \\u043e\\u0442\\u043d\\u043e\\u0441\\u0438\\u0442\\u0441\\u044f \\u043a \\\"\\u043b\\u044e\\u0434\\u0438\\\". \\u041e\\u043d\\u043e \\u0441\\u0442\\u043e\\u0438\\u0442 \\u043f\\u043e\\u0441\\u043b\\u0435 \\\"\\u043b\\u044e\\u0434\\u0438\\\" \\u0438 \\u043f\\u0435\\u0440\\u0435\\u0434 \\\"\\u043c\\u0435\\u043d\\u044f \\u043b\\u044e\\u0431\\u044f\\u0442\\\"? \\u041d\\u0430 \\u0441\\u0430\\u043c\\u043e\\u043c \\u0434\\u0435\\u043b\\u0435, \\u043f\\u043e\\u0440\\u044f\\u0434\\u043e\\u043a \\u0441\\u043b\\u043e\\u0432: \\\"\\u0412\\u0441\\u0435 \\u0443\\u0447\\u0438\\u0442\\u0435\\u043b\\u044f \\u0438 \\u0432\\u0437\\u0440\\u043e\\u0441\\u043b\\u044b\\u0435 \\u043b\\u044e\\u0434\\u0438 \\u0443\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435 \\u043c\\u0435\\u043d\\u044f \\u0437\\u043d\\u0430\\u044e\\u0442 \\u043c\\u0435\\u043d\\u044f \\u043b\\u044e\\u0431\\u044f\\u0442\\\". \\u0422\\u043e \\u0435\\u0441\\u0442\\u044c \\u043f\\u043e\\u0441\\u043b\\u0435 \\\"\\u043b\\u044e\\u0434\\u0438\\\" \\u0438\\u0434\\u0435\\u0442 \\\"\\u0443\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435 \\u043c\\u0435\\u043d\\u044f \\u0437\\u043d\\u0430\\u044e\\u0442\\\", \\u0437\\u0430\\u0442\\u0435\\u043c \\\"\\u043c\\u0435\\u043d\\u044f \\u043b\\u044e\\u0431\\u044f\\u0442\\\". \\u041d\\u043e \\\"\\u043c\\u0435\\u043d\\u044f \\u043b\\u044e\\u0431\\u044f\\u0442\\\" \\u2014 \\u044d\\u0442\\u043e \\u043f\\u0440\\u043e\\u0434\\u043e\\u043b\\u0436\\u0435\\u043d\\u0438\\u0435 \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439. \\u0422\\u043e \\u0435\\u0441\\u0442\\u044c \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u0447\\u0430\\u0441\\u0442\\u044c: \\\"\\u0412\\u0441\\u0435 \\u0443\\u0447\\u0438\\u0442\\u0435\\u043b\\u044f \\u0438 \\u0432\\u0437\\u0440\\u043e\\u0441\\u043b\\u044b\\u0435 \\u043b\\u044e\\u0434\\u0438 ... \\u043c\\u0435\\u043d\\u044f \\u043b\\u044e\\u0431\\u044f\\u0442\\\". \\u041c\\u0435\\u0436\\u0434\\u0443 \\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0438\\u043c \\\"\\u043b\\u044e\\u0434\\u0438\\\" \\u0438 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u044b\\u043c \\\"\\u043b\\u044e\\u0431\\u044f\\u0442\\\" \\u0432\\u0441\\u0442\\u0430\\u0432\\u043b\\u0435\\u043d\\u043e \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435. \\u0422\\u0430\\u043a\\u0438\\u043c \\u043e\\u0431\\u0440\\u0430\\u0437\\u043e\\u043c, \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u0447\\u0430\\u0441\\u0442\\u044c \\u0440\\u0430\\u0437\\u043e\\u0440\\u0432\\u0430\\u043d\\u0430. \\u0427\\u0442\\u043e\\u0431\\u044b \\u043f\\u043e\\u043b\\u0443\\u0447\\u0438\\u0442\\u044c \\u043d\\u0435\\u043f\\u0440\\u0435\\u0440\\u044b\\u0432\\u043d\\u0443\\u044e \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u0443 \\u0434\\u043b\\u044f \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439, \\u043d\\u0443\\u0436\\u043d\\u043e \\u0432\\u0437\\u044f\\u0442\\u044c \\u0432\\u0441\\u0451 \\u043e\\u0442 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0434\\u043e \\u043a\\u043e\\u043d\\u0446\\u0430, \\u0432\\u043a\\u043b\\u044e\\u0447\\u0430\\u044f \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435. \\u041d\\u043e \\u0442\\u043e\\u0433\\u0434\\u0430 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435 \\u0431\\u0443\\u0434\\u0435\\u0442 \\u0432\\u043d\\u0443\\u0442\\u0440\\u0438. \\u0415\\u0441\\u043b\\u0438 \\u043c\\u044b \\u0432\\u044b\\u0434\\u0435\\u043b\\u0438\\u043c \\u0433\\u043b\\u0430\\u0432\\u043d\\u0443\\u044e \\u043a\\u0430\\u043a \\\"\\u0412\\u0441\\u0435 \\u0443\\u0447\\u0438\\u0442\\u0435\\u043b\\u044f \\u0438 \\u0432\\u0437\\u0440\\u043e\\u0441\\u043b\\u044b\\u0435 \\u043b\\u044e\\u0434\\u0438 \\u0443\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435 \\u043c\\u0435\\u043d\\u044f \\u0437\\u043d\\u0430\\u044e\\u0442 \\u043c\\u0435\\u043d\\u044f \\u043b\\u044e\\u0431\\u044f\\u0442 \\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e\\\", \\u0442\\u043e \\u044d\\u0442\\u043e \\u0432\\u043a\\u043b\\u044e\\u0447\\u0430\\u0435\\u0442 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435. \\u0410 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435 \\u043a\\u0430\\u043a \\u043e\\u0442\\u0434\\u0435\\u043b\\u044c\\u043d\\u0443\\u044e \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u0443 \\\"\\u0443\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435 \\u043c\\u0435\\u043d\\u044f \\u0437\\u043d\\u0430\\u044e\\u0442\\\". \\u041e\\u043d\\u0438 \\u043f\\u0435\\u0440\\u0435\\u0441\\u0435\\u043a\\u0430\\u044e\\u0442\\u0441\\u044f: \\u043e\\u0434\\u043d\\u0430 \\u0441\\u043e\\u0434\\u0435\\u0440\\u0436\\u0438\\u0442 \\u0434\\u0440\\u0443\\u0433\\u0443\\u044e. \\u042d\\u0442\\u043e \\u0432\\u043e\\u0437\\u043c\\u043e\\u0436\\u043d\\u043e. \\u0422\\u043e\\u0433\\u0434\\u0430 \\u0442\\u0440\\u0435\\u0442\\u044c\\u044f \\u043a\\u043b\\u0430\\u0443\\u0437\\u0430: \\\"\\u0447\\u0442\\u043e \\u044f \\u0432\\u0441\\u0435\\u0433\\u0434\\u0430 \\u0438\\u043c \\u0434\\u043e\\u0431\\u0440\\u043e\\u0432\\u043e\\u043b\\u044c\\u043d\\u043e \\u043f\\u043e\\u043c\\u043e\\u0433\\u0430\\u044e \\u0438 \\u0442\\u0434\\\". \\u041d\\u043e \\u0433\\u0434\\u0435 \\u0437\\u0430\\u043a\\u0430\\u043d\\u0447\\u0438\\u0432\\u0430\\u0435\\u0442\\u0441\\u044f \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f? \\u0412 \\u043a\\u043e\\u043d\\u0446\\u0435 \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u044f \\u0441\\u0442\\u043e\\u0438\\u0442 \\\"\\u0438 \\u0442\\u0434.\\\" \\u2014 \\u0442\\u043e\\u0447\\u043a\\u0430. \\u0413\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u0432\\u043a\\u043b\\u044e\\u0447\\u0430\\u0435\\u0442 \\\"\\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e\\\", \\u0430 \\u0437\\u0430\\u0442\\u0435\\u043c \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435 \\u043f\\u0440\\u0438\\u0447\\u0438\\u043d\\u044b. \\u041f\\u043e \\u043f\\u0440\\u0430\\u0432\\u0438\\u043b\\u0443, \\\"\\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e\\\" \\u2014 \\u0443\\u043a\\u0430\\u0437\\u0430\\u0442\\u0435\\u043b\\u044c\\u043d\\u043e\\u0435 \\u0441\\u043b\\u043e\\u0432\\u043e, \\u043e\\u0441\\u0442\\u0430\\u0435\\u0442\\u0441\\u044f \\u0432 \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439. \\u0417\\u043d\\u0430\\u0447\\u0438\\u0442, \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u043a\\u043b\\u0430\\u0443\\u0437\\u0430 \\u0434\\u043e\\u043b\\u0436\\u043d\\u0430 \\u0437\\u0430\\u043a\\u0430\\u043d\\u0447\\u0438\\u0432\\u0430\\u0442\\u044c\\u0441\\u044f \\u043d\\u0430 \\\"\\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e\\\"? \\u041d\\u043e \\u0442\\u043e\\u0433\\u0434\\u0430 \\u043f\\u043e\\u0441\\u043b\\u0435 \\\"\\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e\\\" \\u0438\\u0434\\u0435\\u0442 \\u0437\\u0430\\u043f\\u044f\\u0442\\u0430\\u044f? \\u0412 \\u0442\\u0435\\u043a\\u0441\\u0442\\u0435 \\u043d\\u0435\\u0442 \\u0437\\u0430\\u043f\\u044f\\u0442\\u043e\\u0439? \\\"\\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e, \\u0447\\u0442\\u043e\\\" \\u2014 \\u0432 \\u0438\\u0441\\u0445\\u043e\\u0434\\u043d\\u043e\\u043c \\u043d\\u0430\\u043f\\u0438\\u0441\\u0430\\u043d\\u043e \\\"\\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e, \\u0447\\u0442\\u043e\\\"? \\u0412 \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0438 \\u0434\\u0430\\u043d\\u043e: \\\"\\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e, \\u0447\\u0442\\u043e\\\" \\u2014 \\u0435\\u0441\\u0442\\u044c \\u0437\\u0430\\u043f\\u044f\\u0442\\u0430\\u044f? \\u0412 \\u0438\\u0441\\u0445\\u043e\\u0434\\u043d\\u043e\\u043c \\u0442\\u0435\\u043a\\u0441\\u0442\\u0435: \\\"\\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e, \\u0447\\u0442\\u043e\\\" \\u2014 \\u044f \\u0432\\u0438\\u0436\\u0443 \\u0432 \\u0437\\u0430\\u0434\\u0430\\u043d\\u0438\\u0438: \\\"\\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e, \\u0447\\u0442\\u043e\\\" \\u2014 \\u0435\\u0441\\u0442\\u044c \\u0437\\u0430\\u043f\\u044f\\u0442\\u0430\\u044f? \\u041f\\u043e\\u043b\\u044c\\u0437\\u043e\\u0432\\u0430\\u0442\\u0435\\u043b\\u044c \\u043d\\u0430\\u043f\\u0438\\u0441\\u0430\\u043b: \\\"\\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e, \\u0447\\u0442\\u043e\\\" \\u2014 \\u0434\\u0430, \\u0442\\u0430\\u043c \\u0437\\u0430\\u043f\\u044f\\u0442\\u0430\\u044f. \\u041d\\u043e \\u0432 \\u043f\\u0440\\u0430\\u0432\\u0438\\u043b\\u0435 \\u043c\\u044b \\u043d\\u0435 \\u0432\\u043a\\u043b\\u044e\\u0447\\u0430\\u0435\\u043c \\u0437\\u043d\\u0430\\u043a\\u0438 \\u043f\\u0440\\u0435\\u043f\\u0438\\u043d\\u0430\\u043d\\u0438\\u044f \\u043d\\u0430 \\u0433\\u0440\\u0430\\u043d\\u0438\\u0446\\u0430\\u0445. \\u0417\\u043d\\u0430\\u0447\\u0438\\u0442, \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u043a\\u043b\\u0430\\u0443\\u0437\\u0430 \\u0434\\u043e\\u043b\\u0436\\u043d\\u0430 \\u0437\\u0430\\u043a\\u0430\\u043d\\u0447\\u0438\\u0432\\u0430\\u0442\\u044c\\u0441\\u044f \\u043d\\u0430 \\\"\\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e\\\" (\\u0431\\u0435\\u0437 \\u0437\\u0430\\u043f\\u044f\\u0442\\u043e\\u0439), \\u0430 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u0430\\u044f \\u043d\\u0430\\u0447\\u0438\\u043d\\u0430\\u0442\\u044c\\u0441\\u044f \\u0441 \\\"\\u0447\\u0442\\u043e\\\". \\u041d\\u043e \\\"\\u0447\\u0442\\u043e\\\" \\u2014 \\u044d\\u0442\\u043e \\u0441\\u043e\\u044e\\u0437, \\u043e\\u043d \\u043d\\u0430\\u0447\\u0438\\u043d\\u0430\\u0435\\u0442 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u0443\\u044e. \\u0422\\u0430\\u043a \\u0447\\u0442\\u043e \\u0433\\u0440\\u0430\\u043d\\u0438\\u0446\\u0430 \\u043c\\u0435\\u0436\\u0434\\u0443 \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439 \\u0438 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0439 \\u043f\\u0440\\u043e\\u0445\\u043e\\u0434\\u0438\\u0442 \\u043f\\u0435\\u0440\\u0435\\u0434 \\\"\\u0447\\u0442\\u043e\\\". \\u041d\\u043e \\u0432 \\u0442\\u0435\\u043a\\u0441\\u0442\\u0435 \\u0435\\u0441\\u0442\\u044c \\u0437\\u0430\\u043f\\u044f\\u0442\\u0430\\u044f \\u043f\\u0435\\u0440\\u0435\\u0434 \\\"\\u0447\\u0442\\u043e\\\". \\u041c\\u044b \\u0435\\u0435 \\u043d\\u0435 \\u0432\\u043a\\u043b\\u044e\\u0447\\u0430\\u0435\\u043c \\u043d\\u0438 \\u0432 \\u043e\\u0434\\u043d\\u0443 \\u043a\\u043b\\u0430\\u0443\\u0437\\u0443. \\u0422\\u0430\\u043a \\u0447\\u0442\\u043e \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u043a\\u043b\\u0430\\u0443\\u0437\\u0430: \\u043e\\u0442 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0434\\u043e \\\"\\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e\\\" (\\u0432\\u043a\\u043b\\u044e\\u0447\\u0430\\u044f \\\"\\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e\\\"), \\u043d\\u043e \\u043d\\u0435 \\u0432\\u043a\\u043b\\u044e\\u0447\\u0430\\u044f \\u0437\\u0430\\u043f\\u044f\\u0442\\u0443\\u044e. \\u041e\\u0434\\u043d\\u0430\\u043a\\u043e \\u0432\\u043d\\u0443\\u0442\\u0440\\u0438 \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439 \\u0435\\u0441\\u0442\\u044c \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435 \\u043e\\u043f\\u0440\\u0435\\u0434\\u0435\\u043b\\u0438\\u0442\\u0435\\u043b\\u044c\\u043d\\u043e\\u0435. \\u041a\\u0430\\u043a \\u0431\\u044b\\u0442\\u044c \\u0441 \\u043d\\u0438\\u043c? \\u041d\\u0443\\u0436\\u043d\\u043e \\u0442\\u0430\\u043a\\u0436\\u0435 \\u0432\\u044b\\u0434\\u0435\\u043b\\u0438\\u0442\\u044c \\u0435\\u0433\\u043e. \\u041e\\u043f\\u0440\\u0435\\u0434\\u0435\\u043b\\u0438\\u0442\\u0435\\u043b\\u044c\\u043d\\u043e\\u0435 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435 \\u043d\\u0430\\u0447\\u0438\\u043d\\u0430\\u0435\\u0442\\u0441\\u044f \\u0441 \\\"\\u0443\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435\\\" (\\u0441\\u043e\\u044e\\u0437\\u043d\\u043e\\u0435 \\u0441\\u043b\\u043e\\u0432\\u043e). \\u041f\\u0435\\u0440\\u0435\\u0434 \\u043d\\u0438\\u043c \\u043d\\u0435\\u0442 \\u0437\\u0430\\u043f\\u044f\\u0442\\u043e\\u0439? \\u0412 \\u0442\\u0435\\u043a\\u0441\\u0442\\u0435: \\\"\\u043b\\u044e\\u0434\\u0438 \\u0443\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435\\\" \\u2014 \\u0431\\u0435\\u0437 \\u0437\\u0430\\u043f\\u044f\\u0442\\u043e\\u0439. \\u0417\\u043d\\u0430\\u0447\\u0438\\u0442, \\u0433\\u0440\\u0430\\u043d\\u0438\\u0446\\u0430 \\u043f\\u0435\\u0440\\u0435\\u0434 \\\"\\u0443\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435\\\". \\u0413\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u0447\\u0430\\u0441\\u0442\\u044c \\u0434\\u043e \\\"\\u0443\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435\\\" \\u2014 \\\"\\u0412\\u0441\\u0435 \\u0443\\u0447\\u0438\\u0442\\u0435\\u043b\\u044f \\u0438 \\u0432\\u0437\\u0440\\u043e\\u0441\\u043b\\u044b\\u0435 \\u043b\\u044e\\u0434\\u0438\\\". \\u0417\\u0430\\u0442\\u0435\\u043c \\u043f\\u043e\\u0441\\u043b\\u0435 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0433\\u043e \\u043f\\u0440\\u043e\\u0434\\u043e\\u043b\\u0436\\u0435\\u043d\\u0438\\u0435 \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439: \\\" \\u043c\\u0435\\u043d\\u044f \\u043b\\u044e\\u0431\\u044f\\u0442 \\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e\\\". \\u041d\\u043e \\u044d\\u0442\\u043e \\u0440\\u0430\\u0437\\u0440\\u044b\\u0432\\u0430\\u0435\\u0442 \\u0433\\u043b\\u0430\\u0432\\u043d\\u0443\\u044e \\u043d\\u0430 \\u0434\\u0432\\u0435 \\u0447\\u0430\\u0441\\u0442\\u0438. \\u0415\\u0441\\u043b\\u0438 \\u043c\\u044b \\u0445\\u043e\\u0442\\u0438\\u043c \\u043f\\u043e\\u043b\\u0443\\u0447\\u0438\\u0442\\u044c \\u0433\\u043b\\u0430\\u0432\\u043d\\u0443\\u044e \\u043a\\u0430\\u043a \\u043d\\u0435\\u043f\\u0440\\u0435\\u0440\\u044b\\u0432\\u043d\\u0443\\u044e \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u0443, \\u043c\\u044b \\u0434\\u043e\\u043b\\u0436\\u043d\\u044b \\u0432\\u0437\\u044f\\u0442\\u044c \\u0432\\u0435\\u0441\\u044c \\u043e\\u0442\\u0440\\u0435\\u0437\\u043e\\u043a \\u043e\\u0442 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0434\\u043e \\u043a\\u043e\\u043d\\u0446\\u0430 \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439, \\u0432\\u043a\\u043b\\u044e\\u0447\\u0430\\u044f \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435. \\u0422\\u043e \\u0435\\u0441\\u0442\\u044c \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u043a\\u043b\\u0430\\u0443\\u0437\\u0430 \\u0431\\u0443\\u0434\\u0435\\u0442: \\\"\\u0412\\u0441\\u0435 \\u0443\\u0447\\u0438\\u0442\\u0435\\u043b\\u044f \\u0438 \\u0432\\u0437\\u0440\\u043e\\u0441\\u043b\\u044b\\u0435 \\u043b\\u044e\\u0434\\u0438 \\u0443\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435 \\u043c\\u0435\\u043d\\u044f \\u0437\\u043d\\u0430\\u044e\\u0442 \\u043c\\u0435\\u043d\\u044f \\u043b\\u044e\\u0431\\u044f\\u0442 \\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e\\\". \\u041d\\u043e \\u0442\\u043e\\u0433\\u0434\\u0430 \\u043e\\u043d\\u0430 \\u0432\\u043a\\u043b\\u044e\\u0447\\u0430\\u0435\\u0442 \\u0432 \\u0441\\u0435\\u0431\\u044f \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435. \\u0418 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435 \\u0431\\u0443\\u0434\\u0435\\u0442 \\u043e\\u0442\\u0434\\u0435\\u043b\\u044c\\u043d\\u043e\\u0439 \\u043a\\u043b\\u0430\\u0443\\u0437\\u043e\\u0439 \\\"\\u0443\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435 \\u043c\\u0435\\u043d\\u044f \\u0437\\u043d\\u0430\\u044e\\u0442\\\". \\u0410 \\u0437\\u0430\\u0442\\u0435\\u043c \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435 \\u043f\\u0440\\u0438\\u0447\\u0438\\u043d\\u044b: \\\"\\u0447\\u0442\\u043e \\u044f \\u0432\\u0441\\u0435\\u0433\\u0434\\u0430 \\u0438\\u043c \\u0434\\u043e\\u0431\\u0440\\u043e\\u0432\\u043e\\u043b\\u044c\\u043d\\u043e \\u043f\\u043e\\u043c\\u043e\\u0433\\u0430\\u044e \\u0438 \\u0442\\u0434\\\". \\u041d\\u043e \\\"\\u0438 \\u0442\\u0434\\\" \\u2014 \\u044d\\u0442\\u043e \\u0447\\u0430\\u0441\\u0442\\u044c \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0433\\u043e? \\u0414\\u0430, \\u043e\\u043d\\u043e \\u0441\\u0442\\u043e\\u0438\\u0442 \\u043f\\u043e\\u0441\\u043b\\u0435 \\\"\\u043f\\u043e\\u043c\\u043e\\u0433\\u0430\\u044e\\\". \\u0418 \\u0432 \\u043a\\u043e\\u043d\\u0446\\u0435 \\u0442\\u043e\\u0447\\u043a\\u0430 \\u2014 \\u0435\\u0435 \\u043d\\u0435 \\u0432\\u043a\\u043b\\u044e\\u0447\\u0430\\u0435\\u043c. \\u0418\\u0442\\u0430\\u043a, \\u0442\\u0440\\u0438 \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b:\\\\n1. \\\"\\u0412\\u0441\\u0435 \\u0443\\u0447\\u0438\\u0442\\u0435\\u043b\\u044f \\u0438 \\u0432\\u0437\\u0440\\u043e\\u0441\\u043b\\u044b\\u0435 \\u043b\\u044e\\u0434\\u0438 \\u0443\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435 \\u043c\\u0435\\u043d\\u044f \\u0437\\u043d\\u0430\\u044e\\u0442 \\u043c\\u0435\\u043d\\u044f \\u043b\\u044e\\u0431\\u044f\\u0442 \\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e\\\"\\\\n2. \\\"\\u0443\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435 \\u043c\\u0435\\u043d\\u044f \\u0437\\u043d\\u0430\\u044e\\u0442\\\"\\\\n3. \\\"\\u0447\\u0442\\u043e \\u044f \\u0432\\u0441\\u0435\\u0433\\u0434\\u0430 \\u0438\\u043c \\u0434\\u043e\\u0431\\u0440\\u043e\\u0432\\u043e\\u043b\\u044c\\u043d\\u043e \\u043f\\u043e\\u043c\\u043e\\u0433\\u0430\\u044e \\u0438 \\u0442\\u0434\\\"\\\\n\\\\n\\u041f\\u0440\\u043e\\u0432\\u0435\\u0440\\u0438\\u043c, \\u0432\\u0441\\u0435 \\u043b\\u0438 \\u043e\\u0441\\u043d\\u043e\\u0432\\u044b \\u0432\\u044b\\u0434\\u0435\\u043b\\u0435\\u043d\\u044b. \\u0412 \\u043f\\u0435\\u0440\\u0432\\u043e\\u0439 \\u043a\\u043b\\u0430\\u0443\\u0437\\u0435 \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430: \\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u0435 \\\"\\u0432\\u0441\\u0435 \\u0443\\u0447\\u0438\\u0442\\u0435\\u043b\\u044f \\u0438 \\u0432\\u0437\\u0440\\u043e\\u0441\\u043b\\u044b\\u0435 \\u043b\\u044e\\u0434\\u0438\\\" (\\u0441\\u043b\\u043e\\u0436\\u043d\\u043e\\u0435 \\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u0435) \\u0438 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u043e\\u0435 \\\"\\u043b\\u044e\\u0431\\u044f\\u0442\\\". \\u0422\\u0430\\u043a\\u0436\\u0435 \\u0435\\u0441\\u0442\\u044c \\\"\\u043c\\u0435\\u043d\\u044f\\\" \\u2014 \\u0434\\u043e\\u043f\\u043e\\u043b\\u043d\\u0435\\u043d\\u0438\\u0435. \\u0412\\u043e \\u0432\\u0442\\u043e\\u0440\\u043e\\u0439: \\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u0435 \\\"\\u043a\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435\\\" (\\u0441\\u043e\\u044e\\u0437\\u043d\\u043e\\u0435 \\u0441\\u043b\\u043e\\u0432\\u043e) \\u0438 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u043e\\u0435 \\\"\\u0437\\u043d\\u0430\\u044e\\u0442\\\". \\u0412 \\u0442\\u0440\\u0435\\u0442\\u044c\\u0435\\u0439: \\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u0435 \\\"\\u044f\\\" \\u0438 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u043e\\u0435 \\\"\\u043f\\u043e\\u043c\\u043e\\u0433\\u0430\\u044e\\\". \\u0412\\u0441\\u0451 \\u0432\\u0435\\u0440\\u043d\\u043e. \\u041d\\u043e \\u0435\\u0441\\u0442\\u044c \\u043b\\u0438 \\u0435\\u0449\\u0435 \\u043e\\u0434\\u043d\\u0430 \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430? \\\"\\u0438 \\u0442\\u0434\\\" \\u043d\\u0435 \\u0434\\u0430\\u0435\\u0442 \\u043e\\u0441\\u043d\\u043e\\u0432\\u044b. \\u0422\\u0430\\u043a\\u0436\\u0435 \\u0435\\u0441\\u0442\\u044c \\u043b\\u0438 \\u0432 \\u043f\\u0435\\u0440\\u0432\\u043e\\u0439 \\u043a\\u043b\\u0430\\u0443\\u0437\\u0435 \\\"\\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e\\\" \\u2014 \\u044d\\u0442\\u043e \\u043e\\u0431\\u0441\\u0442\\u043e\\u044f\\u0442\\u0435\\u043b\\u044c\\u0441\\u0442\\u0432\\u043e \\u043f\\u0440\\u0438\\u0447\\u0438\\u043d\\u044b, \\u043d\\u0435 \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430.\\\\n\\\\n\\u0422\\u0435\\u043f\\u0435\\u0440\\u044c \\u043d\\u0443\\u0436\\u043d\\u043e \\u0443\\u0431\\u0435\\u0434\\u0438\\u0442\\u044c\\u0441\\u044f, \\u0447\\u0442\\u043e \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b \\u044f\\u0432\\u043b\\u044f\\u044e\\u0442\\u0441\\u044f \\u0442\\u043e\\u0447\\u043d\\u044b\\u043c\\u0438 \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u0430\\u043c\\u0438. \\u0418\\u0441\\u0445\\u043e\\u0434\\u043d\\u043e\\u0435 \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0435: \\\"\\u0412\\u0441\\u0435 \\u0443\\u0447\\u0438\\u0442\\u0435\\u043b\\u044f \\u0438 \\u0432\\u0437\\u0440\\u043e\\u0441\\u043b\\u044b\\u0435 \\u043b\\u044e\\u0434\\u0438 \\u0443\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435 \\u043c\\u0435\\u043d\\u044f \\u0437\\u043d\\u0430\\u044e\\u0442 \\u043c\\u0435\\u043d\\u044f \\u043b\\u044e\\u0431\\u044f\\u0442 \\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e, \\u0447\\u0442\\u043e \\u044f \\u0432\\u0441\\u0435\\u0433\\u0434\\u0430 \\u0438\\u043c \\u0434\\u043e\\u0431\\u0440\\u043e\\u0432\\u043e\\u043b\\u044c\\u043d\\u043e \\u043f\\u043e\\u043c\\u043e\\u0433\\u0430\\u044e \\u0438 \\u0442\\u0434.\\\" \\u041e\\u0431\\u0440\\u0430\\u0442\\u0438\\u0442\\u0435 \\u0432\\u043d\\u0438\\u043c\\u0430\\u043d\\u0438\\u0435: \\u043f\\u043e\\u0441\\u043b\\u0435 \\\"\\u0442\\u043e\\u0433\\u043e\\\" \\u0435\\u0441\\u0442\\u044c \\u0437\\u0430\\u043f\\u044f\\u0442\\u0430\\u044f, \\u0437\\u0430\\u0442\\u0435\\u043c \\u043f\\u0440\\u043e\\u0431\\u0435\\u043b, \\u0437\\u0430\\u0442\\u0435\\u043c \\\"\\u0447\\u0442\\u043e\\\". \\u0412 \\u043f\\u0435\\u0440\\u0432\\u043e\\u0439 \\u043a\\u043b\\u0430\\u0443\\u0437\\u0435 \\u043c\\u044b \\u043d\\u0435 \\u0432\\u043a\\u043b\\u044e\\u0447\\u0430\\u0435\\u043c \\u0437\\u0430\\u043f\\u044f\\u0442\\u0443\\u044e, \\u043f\\u043e\\u044d\\u0442\\u043e\\u043c\\u0443 \\u043e\\u043d\\u0430 \\u0437\\u0430\\u043a\\u0430\\u043d\\u0447\\u0438\\u0432\\u0430\\u0435\\u0442\\u0441\\u044f \\u043d\\u0430 \\\"\\u0442\\u043e\\u0433\\u043e\\\" (\\u043f\\u043e\\u0441\\u043b\\u0435\\u0434\\u043d\\u044f\\u044f \\u0431\\u0443\\u043a\\u0432\\u0430 \\\"\\u043e\\\"). \\u0422\\u043e \\u0435\\u0441\\u0442\\u044c \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u0430: \\\"\\u0412\\u0441\\u0435 \\u0443\\u0447\\u0438\\u0442\\u0435\\u043b\\u044f \\u0438 \\u0432\\u0437\\u0440\\u043e\\u0441\\u043b\\u044b\\u0435 \\u043b\\u044e\\u0434\\u0438 \\u0443\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435 \\u043c\\u0435\\u043d\\u044f \\u0437\\u043d\\u0430\\u044e\\u0442 \\u043c\\u0435\\u043d\\u044f \\u043b\\u044e\\u0431\\u044f\\u0442 \\u0438\\u0437-\\u0437\\u0430 \\u0442\\u043e\\u0433\\u043e\\\". \\u042d\\u0442\\u043e \\u0435\\u0441\\u0442\\u044c \\u0432 \\u0442\\u0435\\u043a\\u0441\\u0442\\u0435? \\u0414\\u0430, \\u0441 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0434\\u043e \\\"\\u0442\\u043e\\u0433\\u043e\\\" \\u0432\\u043a\\u043b\\u044e\\u0447\\u0438\\u0442\\u0435\\u043b\\u044c\\u043d\\u043e, \\u043d\\u043e \\u0431\\u0435\\u0437 \\u0437\\u0430\\u043f\\u044f\\u0442\\u043e\\u0439. \\u0412\\u0442\\u043e\\u0440\\u0430\\u044f \\u043a\\u043b\\u0430\\u0443\\u0437\\u0430: \\\"\\u0443\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435 \\u043c\\u0435\\u043d\\u044f \\u0437\\u043d\\u0430\\u044e\\u0442\\\". \\u041e\\u043d\\u0430 \\u043d\\u0430\\u0447\\u0438\\u043d\\u0430\\u0435\\u0442\\u0441\\u044f \\u0441 \\\"\\u0443\\\" \\u0438 \\u0437\\u0430\\u043a\\u0430\\u043d\\u0447\\u0438\\u0432\\u0430\\u0435\\u0442\\u0441\\u044f \\u043d\\u0430 \\\"\\u044e\\u0442\\\". \\u0412 \\u0442\\u0435\\u043a\\u0441\\u0442\\u0435 \\u043f\\u043e\\u0441\\u043b\\u0435 \\\"\\u043b\\u044e\\u0434\\u0438\\\" \\u0438\\u0434\\u0435\\u0442 \\u043f\\u0440\\u043e\\u0431\\u0435\\u043b, \\u0437\\u0430\\u0442\\u0435\\u043c \\\"\\u0443\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435\\\". \\u0422\\u0430\\u043a \\u0447\\u0442\\u043e \\u044d\\u0442\\u043e \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u0430. \\u0422\\u0440\\u0435\\u0442\\u044c\\u044f: \\\"\\u0447\\u0442\\u043e \\u044f \\u0432\\u0441\\u0435\\u0433\\u0434\\u0430 \\u0438\\u043c \\u0434\\u043e\\u0431\\u0440\\u043e\\u0432\\u043e\\u043b\\u044c\\u043d\\u043e \\u043f\\u043e\\u043c\\u043e\\u0433\\u0430\\u044e \\u0438 \\u0442\\u0434\\\". \\u041d\\u0430\\u0447\\u0438\\u043d\\u0430\\u0435\\u0442\\u0441\\u044f \\u0441 \\\"\\u0447\\\" \\u043f\\u043e\\u0441\\u043b\\u0435 \\u0437\\u0430\\u043f\\u044f\\u0442\\u043e\\u0439 \\u0438 \\u043f\\u0440\\u043e\\u0431\\u0435\\u043b\\u0430? \\u0412 \\u0442\\u0435\\u043a\\u0441\\u0442\\u0435: \\\", \\u0447\\u0442\\u043e \\u044f ...\\\" \\u2014 \\u0437\\u0430\\u043f\\u044f\\u0442\\u0430\\u044f, \\u043f\\u0440\\u043e\\u0431\\u0435\\u043b, \\\"\\u0447\\u0442\\u043e\\\". \\u041c\\u044b \\u043d\\u0435 \\u0432\\u043a\\u043b\\u044e\\u0447\\u0430\\u0435\\u043c \\u0437\\u0430\\u043f\\u044f\\u0442\\u0443\\u044e \\u0438 \\u043f\\u0440\\u043e\\u0431\\u0435\\u043b? \\u041a\\u043b\\u0430\\u0443\\u0437\\u0430 \\u0434\\u043e\\u043b\\u0436\\u043d\\u0430 \\u043d\\u0430\\u0447\\u0438\\u043d\\u0430\\u0442\\u044c\\u0441\\u044f \\u0441 \\u043f\\u0435\\u0440\\u0432\\u043e\\u0439 \\u0431\\u0443\\u043a\\u0432\\u044b, \\u0442\\u043e \\u0435\\u0441\\u0442\\u044c \\u0441 \\\"\\u0447\\\". \\u041d\\u043e \\u043f\\u0435\\u0440\\u0435\\u0434 \\\"\\u0447\\u0442\\u043e\\\" \\u0435\\u0441\\u0442\\u044c \\u0437\\u0430\\u043f\\u044f\\u0442\\u0430\\u044f \\u0438 \\u043f\\u0440\\u043e\\u0431\\u0435\\u043b. \\u0417\\u043d\\u0430\\u