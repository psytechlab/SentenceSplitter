u0434\\u0447\\u0438\\u043d\\u0435\\u043d\\u043d\\u044b\\u043c. \\u0421\\u043b\\u043e\\u0436\\u043d\\u043e\\u043f\\u043e\\u0434\\u0447\\u0438\\u043d\\u0435\\u043d\\u043d\\u043e\\u0435 \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0435 \\u0441\\u043e\\u0441\\u0442\\u043e\\u0438\\u0442 \\u0438\\u0437 \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439 \\u0438 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0439 \\u0447\\u0430\\u0441\\u0442\\u0435\\u0439. \\u0413\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u0447\\u0430\\u0441\\u0442\\u044c \\u0441\\u043e\\u0434\\u0435\\u0440\\u0436\\u0438\\u0442 \\u043e\\u0434\\u043d\\u043e\\u0440\\u043e\\u0434\\u043d\\u044b\\u0435 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u044b\\u0435. \\u0422\\u043e \\u0435\\u0441\\u0442\\u044c \\u0432\\u0441\\u0435\\u0433\\u043e \\u0434\\u0432\\u0435 \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b: \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u0438 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u0430\\u044f. \\u0410 \\u0437\\u0430\\u0442\\u0435\\u043c \\u0435\\u0449\\u0435 \\\"\\u043d\\u043e \\u043e\\u043d\\u0430 \\u043f\\u0440\\u043e\\u0434\\u043e\\u043b\\u0436\\u0430\\u0435\\u0442 \\u043c\\u0435\\u043d\\u044f \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u043e\\u0432\\u0430\\u0442\\u044c\\\" - \\u044d\\u0442\\u043e \\u0442\\u0440\\u0435\\u0442\\u044c\\u044f \\u043a\\u043b\\u0430\\u0443\\u0437\\u0430, \\u0441\\u043e\\u0435\\u0434\\u0438\\u043d\\u0435\\u043d\\u043d\\u0430\\u044f \\u0441\\u043e\\u0447\\u0438\\u043d\\u0438\\u0442\\u0435\\u043b\\u044c\\u043d\\u043e\\u0439 \\u0441\\u0432\\u044f\\u0437\\u044c\\u044e? \\u041d\\u043e \\u0441\\u043e\\u044e\\u0437 \\\"\\u043d\\u043e\\\" \\u0441\\u043e\\u0435\\u0434\\u0438\\u043d\\u044f\\u0435\\u0442 \\u0447\\u0430\\u0441\\u0442\\u0438 \\u0441\\u043b\\u043e\\u0436\\u043d\\u043e\\u0441\\u043e\\u0447\\u0438\\u043d\\u0435\\u043d\\u043d\\u043e\\u0433\\u043e \\u043f\\u0440\\u0435\\u