440\\u0430\\u0434\\u0438\\u0446\\u0438\\u043e\\u043d\\u043d\\u043e\\u0439 \\u0433\\u0440\\u0430\\u043c\\u043c\\u0430\\u0442\\u0438\\u043a\\u0438.\\\\n\\\\n\\u0422\\u0440\\u0430\\u0434\\u0438\\u0446\\u0438\\u043e\\u043d\\u043d\\u043e, \\u0432 \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0438 \\\"\\u042f \\u0438 \\u0441\\u0430\\u043c\\u0430 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c, \\u0447\\u0442\\u043e \\u043e\\u043d\\u0430 \\u043c\\u0435\\u043d\\u044f \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u0443\\u0435\\u0442, \\u0438 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c \\u0441 \\u043d\\u0435\\u0439 \\u0445\\u043e\\u043b\\u043e\\u0434\\u043d\\u0435\\u0435, \\u043d\\u043e \\u043e\\u043d\\u0430 \\u043f\\u0440\\u043e\\u0434\\u043e\\u043b\\u0436\\u0430\\u0435\\u0442 \\u043c\\u0435\\u043d\\u044f \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u043e\\u0432\\u0430\\u0442\\u044c\\\" - \\u0441\\u043a\\u043e\\u043b\\u044c\\u043a\\u043e \\u043f\\u0440\\u0435\\u0434\\u0438\\u043a\\u0430\\u0442\\u0438\\u0432\\u043d\\u044b\\u0445 \\u0446\\u0435\\u043d\\u0442\\u0440\\u043e\\u0432? \\u0421\\u0447\\u0438\\u0442\\u0430\\u0435\\u043c \\u0433\\u043b\\u0430\\u0433\\u043e\\u043b\\u044b \\u0432 \\u043b\\u0438\\u0447\\u043d\\u043e\\u0439 \\u0444\\u043e\\u0440\\u043c\\u0435: \\\"\\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c\\\" (\\u0441\\u043e\\u0441\\u0442\\u0430\\u0432\\u043d\\u043e\\u0435, \\u043d\\u043e \\u043e\\u0434\\u043d\\u043e \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u043e\\u0435), \\\"\\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u0443\\u0435\\u0442\\\", \\\"\\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c\\\", \\\"\\u043f\\u0440\\u043e\\u0434\\u043e\\u043b\\u0436\\u0430\\u0435\\u0442 \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u043e\\u0432\\u0430\\u0442\\u044c\\\". \\u0418\\u0442\\u043e\\u0433\\u043e 4 \\u0433\\u043b\\u0430\\u0433\\u043e\\u043b\\u044c\\u043d\\u044b\\u0445 \\u0444\\u043e\\u0440\\u043c, \\u043d\\u043e \\\"\\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c\\\" \\u0438 \\\"\\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c\\\" - \\u044d\\u0442\\u043e \\u0434\\u0432\\u0430 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u044b\\u0445 \\u043f\\u0440\\u0438 \\u043e\\u0434\\u043d\\u043e\\u043c \\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u043c. \\u0421\\u0447\\u0438\\u0442\\u0430\\u0435\\u0442\\u0441\\u044f \\u043b\\u0438 \\u043a\\u0430\\u0436\\u0434\\u043e\\u0435 \\u0438\\u0437 \\u043d\\u0438\\u0445 \\u043e\\u0442\\u0434\\u0435\\u043b\\u044c\\u043d\\u043e\\u0439 \\u043f\\u0440\\u0435\\u0434\\u0438\\u043a\\u0430\\u0442\\u0438\\u0432\\u043d\\u043e\\u0439 \\u0435\\u0434\\u0438\\u043d\\u0438\\u0446\\u0435\\u0439? \\u0412 \\u0440\\u0443\\u0441\\u0441\\u043a\\u043e\\u043c \\u044f\\u0437\\u044b\\u043a\\u0435 \\u0432 \\u043f\\u0440\\u043e\\u0441\\u0442\\u043e\\u043c \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0438 \\u0441 \\u043e\\u0434\\u043d\\u043e\\u0440\\u043e\\u0434\\u043d\\u044b\\u043c\\u0438 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u044b\\u043c\\u0438 - \\u043e\\u0434\\u043d\\u0430 \\u043f\\u0440\\u0435\\u0434\\u0438\\u043a\\u0430\\u0442\\u0438\\u0432\\u043d\\u0430\\u044f \\u0435\\u0434\\u0438\\u043d\\u0438\\u0446\\u0430. \\u041e\\u0434\\u043d\\u0430\\u043a\\u043e \\u0432 \\u0441\\u043b\\u043e\\u0436\\u043d\\u043e\\u043c \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0438, \\u0435\\u0441\\u043b\\u0438 \\u0435\\u0441\\u0442\\u044c \\u043f\\u0440\\ufffd\\ufffd\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435, \\u