 \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u0447\\u0430\\u0441\\u0442\\u044c \\u043d\\u0435 \\u044f\\u0432\\u043b\\u044f\\u0435\\u0442\\u0441\\u044f \\u043d\\u0435\\u043f\\u0440\\u0435\\u0440\\u044b\\u0432\\u043d\\u043e\\u0439 \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u043e\\u0439. \\u041a\\u0430\\u043a \\u0431\\u044b\\u0442\\u044c? \\u0412\\u043e\\u0437\\u043c\\u043e\\u0436\\u043d\\u043e, \\u043c\\u044b \\u043c\\u043e\\u0436\\u0435\\u043c \\u043f\\u0440\\u0435\\u0434\\u0441\\u0442\\u0430\\u0432\\u0438\\u0442\\u044c \\u0433\\u043b\\u0430\\u0432\\u043d\\u0443\\u044e \\u0447\\u0430\\u0441\\u0442\\u044c \\u043a\\u0430\\u043a \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u0443, \\u043a\\u043e\\u0442\\u043e\\u0440\\u0430\\u044f \\u0432\\u043a\\u043b\\u044e\\u0447\\u0430\\u0435\\u0442 \\u0432 \\u0441\\u0435\\u0431\\u044f \\u0438 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u0443\\u044e? \\u041d\\u043e \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u0430\\u044f - \\u043e\\u0442\\u0434\\u0435\\u043b\\u044c\\u043d\\u0430\\u044f \\u043a\\u043b\\u0430\\u0443\\u0437\\u0430, \\u043d\\u0435 \\u0432\\u0445\\u043e\\u0434\\u0438\\u0442 \\u0432 \\u0433\\u043b\\u0430\\u0432\\u043d\\u0443\\u044e. \\u0415\\u0441\\u043b\\u0438 \\u043c\\u044b \\u0432\\u043e\\u0437\\u044c\\u043c\\u0435\\u043c \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u0443 \\\"\\u042f \\u0438 \\u0441\\u0430\\u043c\\u0430 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c, \\u0447\\u0442\\u043e \\u043e\\u043d\\u0430 \\u043c\\u0435\\u043d\\u044f \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u0443\\u0435\\u0442, \\u0438 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c \\u0441 \\u043d\\u0435\\u0439 \\u0445\\u043e\\u043b\\u043e\\u0434\\u043d\\u0435\\u0435\\\", \\u0442\\u043e \\u044d\\u0442\\u043e \\u0431\\u0443\\u