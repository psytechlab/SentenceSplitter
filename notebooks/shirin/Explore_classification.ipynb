f\\u0440\\u043e\\u0441\\u0442\\u043e\\u0435 \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0435 - \\u044d\\u0442\\u043e \\u043f\\u0440\\u0435\\u0434\\u0438\\u043a\\u0430\\u0442\\u0438\\u0432\\u043d\\u0430\\u044f \\u0435\\u0434\\u0438\\u043d\\u0438\\u0446\\u0430. \\u0415\\u0441\\u043b\\u0438 \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u0447\\u0430\\u0441\\u0442\\u044c \\u0440\\u0430\\u0437\\u043e\\u0440\\u0432\\u0430\\u043d\\u0430 \\u0432\\u0441\\u0442\\u0430\\u0432\\u043a\\u043e\\u0439, \\u0442\\u043e \\u044d\\u0442\\u043e \\u0432\\u0441\\u0435 \\u0440\\u0430\\u0432\\u043d\\u043e \\u043e\\u0434\\u043d\\u043e \\u043f\\u0440\\u043e\\u0441\\u0442\\u043e\\u0435 \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0435, \\u043d\\u043e \\u043e\\u043d\\u043e \\u043f\\u0440\\u0435\\u0434\\u0441\\u0442\\u0430\\u0432\\u043b\\u0435\\u043d\\u043e \\u0434\\u0432\\u0443\\u043c\\u044f \\u043d\\u0435\\u043f\\u0440\\u0435\\u0440\\u044b\\u0432\\u043d\\u044b\\u043c\\u0438 \\u043e\\u0442\\u0440\\u0435\\u0437\\u043a\\u0430\\u043c\\u0438. \\u0412 \\u043d\\u0435\\u043a\\u043e\\u0442\\u043e\\u0440\\u044b\\u0445 \\u043f\\u043e\\u0434\\u0445\\u043e\\u0434\\u0430\\u0445 \\u0442\\u0430\\u043a\\u0438\\u0435 \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b \\u0432\\u044b\\u0434\\u0435\\u043b\\u044f\\u044e\\u0442 \\u043a\\u0430\\u043a \\u0434\\u0432\\u0435 \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u0438 (\\u043b\\u0435\\u0432\\u0443\\u044e \\u0438 \\u043f\\u0440\\u0430\\u0432\\u0443\\u044e \\u0447\\u0430\\u0441\\u0442\\u0438). \\u041e\\u0434\\u043d\\u0430\\u043a\\u043e \\u0432 \\u043f\\u0440\\u0438\\u043c\\u0435\\u0440\\u0430\\u0445 \\u0442\\u0430\\u043a\\u043e\\u0433\\u043e \\u043d\\u0435 \\u0431\\u044b\\u043b\\u043e. \\u0412 \\u043f\\u0440\\u0438\\u043c\\u0435\\u0440\\u0430\\u0445 \\u0431\\u044b\\u043b\\u0438 \\u043d\\u0435\\u043f\\u0440\\u0435\\u0440\\u044b\\u0432\\u043d\\u044b\\u0435 \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b. \\u0414\\u0430\\u0432\\u0430\\u0439\\u0442\\u0435 \\u043f\\u043e\\u0434\\u0443\\u043c\\u0430\\u0435\\u043c: \\u043a\\u0430\\u043a \\u043f\\u0440\\u0430\\u0432\\u0438\\u043b\\u044c\\u043d\\u043e?\\\\n\\\\n\\u0412 \\u0440\\u0443\\u0441\\u0441\\u043a\\u043e\\u043c \\u044f\\u0437\\u044b\\u043a\\u0435 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435 \\u043c\\u043e\\u0436\\u0435\\u0442 \\u043d\\u0430\\u0445\\u043e\\u0434\\u0438\\u0442\\u044c\\u0441\\u044f \\u0432\\u043d\\u0443\\u0442\\u0440\\u0438 \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0433\\u043e. \\u041d\\u0430\\u043f\\u0440\\u0438\\u043c\\u0435\\u0440: \\\"\\u0414\\u043e\\u043c, \\u043a\\u043e\\u0442\\u043e\\u0440\\u044b\\u0439 \\u0441\\u0442\\u043e\\u0438\\u0442 \\u043d\\u0430 \\u0433\\u043e\\u0440\\u0435, \\u0432\\u0438\\u0434\\u0435\\u043d \\u0438\\u0437\\u0434\\u0430\\u043b\\u0435\\u043a\\u0430.\\\" \\u0417\\u0434\\u0435\\u0441\\u044c \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0435 \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0435 \\\"\\u0414\\u043e\\u043c \\u0432\\u0438\\u0434\\u0435\\u043d \\u0438\\u0437\\u0434\\u0430\\u043b\\u0435\\u043a\\u0430\\\" \\u0440\\u0430\\u0437\\u043e\\u0440\\u0432\\u0430\\u043d\\u043e \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u044b\\u043c. \\u0415\\u0441\\u043b\\u0438 \\u043c\\u044b \\u0432\\u044b\\u0434\\u0435\\u043b\\u044f\\u0435\\u043c \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b, \\u0442\\u043e \\u043f\\u043e\\u043b\\u0443\\u0447\\u0438\\u043c: \\\"\\u0414\\u043e\\u043c \\u0432\\u0438\\u0434\\u0435\\u043d \\u0438\\u0437\\u0434\\u0430\\u043b\\u0435\\u043a\\u0430\\\" (\\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f) \\u0438 \\\"\\u043a\\u043e\\u0442\\u043e\\u0440\\u044b\\u0439 \\u0441\\u0442\\u043e\\u0438\\u0442 \\u043d\\u0430 \\u0433\\u043e\\u0440\\u0435\\\" (\\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u0430\\u044f). \\u041d\\u043e \\\"\\u0414\\u043e\\u043c \\u0432\\u0438\\u0434\\u0435\\u043d \\u0438\\u0437\\u0434\\u0430\\u043b\\u0435\\u043a\\u0430\\\" \\u043d\\u0435 \\u044f\\u0432\\u043b\\u044f\\u0435\\u0442\\u0441\\u044f \\u043d\\u0435\\u043f\\u0440\\u0435\\u0440\\u044b\\u0432\\u043d\\u043e\\u0439 \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u043e\\u0439, \\u0442\\u0430\\u043a \\u043a\\u0430\\u043a \\u043c\\u0435\\u0436\\u0434\\u0443 \\\"\\u0414\\u043e\\u043c\\\" \\u0438 \\\"\\u0432\\u0438\\u0434\\u0435\\u043d\\\" \\u0432\\u0441\\u0442\\u0430\\u0432\\u043b\\u0435\\u043d\\u043e \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435. \\u041a\\u0430\\u043a \\u0431\\u044b\\u0442\\u044c? \\u0412 \\u0442\\u0430\\u043a\\u0438\\u0445 \\u0441\\u043b\\u0443\\u0447\\u0430\\u044f\\u0445 \\u043e\\u0431\\u044b\\u0447\\u043d\\u043e \\u0432\\u043e\\u0437\\u0432\\u0440\\u0430\\u0449\\u0430\\u044e\\u0442 \\\"\\u0414\\u043e\\u043c \\u0432\\u0438\\u0434\\u0435\\u043d \\u0438\\u0437\\u0434\\u0430\\u043b\\u0435\\u043a\\u0430\\\" \\u043a\\u0430\\u043a \\u043e\\u0434\\u043d\\u0443 \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u0443? \\u041d\\u043e \\u043e\\u043d\\u0430 \\u043d\\u0435 \\u044f\\u0432\\u043b\\u044f\\u0435\\u0442\\u0441\\u044f \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u043e\\u0439, \\u043f\\u043e\\u0442\\u043e\\u043c\\u0443 \\u0447\\u0442\\u043e \\u0432 \\u0438\\u0441\\u0445\\u043e\\u0434\\u043d\\u043e\\u0439 \\u0441\\u0442\\u0440\\u043e\\u043a\\u0435 \\u043c\\u0435\\u0436\\u0434\\u0443 \\u043d\\u0438\\u043c\\u0438 \\u0435\\u0441\\u0442\\u044c \\u0434\\u0440\\u0443\\u0433\\u0438\\u0435 \\u0441\\u043b\\u043e\\u0432\\u0430. \\u0417\\u043d\\u0430\\u0447\\u0438\\u0442, \\u044d\\u0442\\u043e \\u043d\\u0435\\u0432\\u043e\\u0437\\u043c\\u043e\\u0436\\u043d\\u043e. \\u0417\\u043d\\u0430\\u0447\\u0438\\u0442, \\u043d\\u0443\\u0436\\u043d\\u043e \\u043b\\u0438\\u0431\\u043e \\u0440\\u0430\\u0437\\u0434\\u0435\\u043b\\u0438\\u0442\\u044c \\u0433\\u043b\\u0430\\u0432\\u043d\\u0443\\u044e \\u043d\\u0430 \\u0434\\u0432\\u0435 \\u0447\\u0430\\u0441\\u0442\\u0438, \\u043b\\u0438\\u0431\\u043e \\u043f\\u0440\\u0438\\u0437\\u043d\\u0430\\u0442\\u044c, \\u0447\\u0442\\u043e \\u0442\\u0430\\u043a\\u043e\\u0435 \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0435 \\u0441\\u043e\\u0434\\u0435\\u0440\\u0436\\u0438\\u0442 \\u0442\\u0440\\u0438 \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b? \\u041d\\u0435\\u0442, \\u0433\\u0440\\u0430\\u043c\\u043c\\u0430\\u0442\\u0438\\u0447\\u0435\\u0441\\u043a\\u0438 \\u0434\\u0432\\u0435 \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b: \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u0438 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u0430\\u044f. \\u041d\\u043e \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u0440\\u0430\\u0437\\u043e\\u0440\\u0432\\u0430\\u043d\\u0430. \\u041d\\u0430 \\u043f\\u0440\\u0430\\u043a\\u0442\\u0438\\u043a\\u0435 \\u0432 \\u0437\\u0430\\u0434\\u0430\\u0447\\u0430\\u0445 \\u0441\\u0438\\u043d\\u0442\\u0430\\u043a\\u0441\\u0438\\u0447\\u0435\\u0441\\u043a\\u043e\\u0433\\u043e \\u0440\\u0430\\u0437\\u0431\\u043e\\u0440\\u0430 \\u0447\\u0430\\u0441\\u0442\\u043e \\u0432\\u044b\\u0434\\u0435\\u043b\\u044f\\u044e\\u0442 \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b \\u043a\\u0430\\u043a \\u043d\\u0435\\u043f\\u0440\\u0435\\u0440\\u044b\\u0432\\u043d\\u044b\\u0435 \\u043e\\u0442\\u0440\\u0435\\u0437\\u043a\\u0438, \\u0438 \\u0435\\u0441\\u043b\\u0438 \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u0440\\u0430\\u0437\\u043e\\u0440\\u0432\\u0430\\u043d\\u0430, \\u0442\\u043e \\u043e\\u043d\\u0430 \\u043f\\u0440\\u0435\\u0434\\u0441\\u0442\\u0430\\u0432\\u043b\\u044f\\u0435\\u0442\\u0441\\u044f \\u0434\\u0432\\u0443\\u043c\\u044f \\u043e\\u0442\\u0440\\u0435\\u0437\\u043a\\u0430\\u043c\\u0438, \\u043a\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435 \\u043e\\u0431\\u044a\\u0435\\u0434\\u0438\\u043d\\u044f\\u044e\\u0442\\u0441\\u044f \\u043f\\u043e \\u0441\\u043c\\u044b\\u0441\\u043b\\u0443. \\u041d\\u043e \\u0437\\u0434\\u0435\\u0441\\u044c \\u0443\\u0441\\u043b\\u043e\\u0432\\u0438\\u0435: \\\"\\u043a\\u0430\\u0436\\u0434\\u0430\\u044f \\u043a\\u043b\\u0430\\u0443\\u0437\\u0430 \\u0434\\u043e\\u043b\\u0436\\u043d\\u0430 \\u0431\\u044b\\u0442\\u044c \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u043e\\u0439 \\u0438\\u0441\\u0445\\u043e\\u0434\\u043d\\u043e\\u0433\\u043e \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u044f\\\" \\u0438 \\\"\\u043d\\u0435 \\u043c\\u0435\\u043d\\u044f\\u0439 \\u0441\\u043b\\u043e\\u0432\\u0430, \\u043d\\u0435 \\u0434\\u043e\\u0431\\u0430\\u0432\\u043b\\u044f\\u0439 \\u0438 \\u043d\\u0435 \\u0443\\u0434\\u0430\\u043b\\u044f\\u0439 \\u0441\\u0438\\u043c\\u0432\\u043e\\u043b\\u044b\\\". \\u0417\\u043d\\u0430\\u0447\\u0438\\u0442, \\u043c\\u044b \\u0434\\u043e\\u043b\\u0436\\u043d\\u044b \\u043d\\u0430\\u0439\\u0442\\u0438 \\u0442\\u0430\\u043a\\u0438\\u0435 \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u0438, \\u043a\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435 \\u0441\\u043e\\u043e\\u0442\\u0432\\u0435\\u0442\\u0441\\u0442\\u0432\\u0443\\u044e\\u0442 \\u043a\\u043b\\u0430\\u0443\\u0437\\u0430\\u043c. \\u0414\\u043b\\u044f \\u0440\\u0430\\u0437\\u043e\\u0440\\u0432\\u0430\\u043d\\u043d\\u043e\\u0439 \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439 \\u0447\\u0430\\u0441\\u0442\\u0438 \\u044d\\u0442\\u043e \\u043d\\u0435\\u0432\\u043e\\u0437\\u043c\\u043e\\u0436\\u043d\\u043e, \\u0435\\u0441\\u043b\\u0438 \\u043c\\u044b \\u043d\\u0435 \\u0440\\u0430\\u0437\\u0434\\u0435\\u043b\\u0438\\u043c \\u0435\\u0435 \\u043d\\u0430 \\u0434\\u0432\\u0435. \\u041d\\u043e \\u0442\\u043e\\u0433\\u0434\\u0430 \\u043f\\u043e\\u043b\\u0443\\u0447\\u0438\\u0442\\u0441\\u044f \\u0434\\u0432\\u0435 \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b \\u0438\\u0437 \\u043e\\u0434\\u043d\\u043e\\u0439 \\u043e\\u0441\\u043d\\u043e\\u0432\\u044b? \\u042d\\u0442\\u043e \\u043f\\u0440\\u043e\\u0442\\u0438\\u0432\\u043e\\u0440\\u0435\\u0447\\u0438\\u0442 \\u043f\\u0440\\u0430\\u0432\\u0438\\u043b\\u0443 1: \\\"\\u043a\\u043e\\u043b\\u0438\\u0447\\u0435\\u0441\\u0442\\u0432\\u043e \\u043a\\u043b\\u0430\\u0443\\u0437 \\u0441\\u0442\\u0440\\u043e\\u0433\\u043e \\u0440\\u0430\\u0432\\u043d\\u043e \\u043a\\u043e\\u043b\\u0438\\u0447\\u0435\\u0441\\u0442\\u0432\\u0443 \\u0433\\u0440\\u0430\\u043c\\u043c\\u0430\\u0442\\u0438\\u0447\\u0435\\u0441\\u043a\\u0438\\u0445 \\u043e\\u0441\\u043d\\u043e\\u0432\\\". \\u0423 \\u043d\\u0430\\u0441 \\u0432 \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439 \\u0447\\u0430\\u0441\\u0442\\u0438 \\u043e\\u0434\\u043d\\u0430 \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430 (\\u042f \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c \\u0438 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c), \\u0437\\u043d\\u0430\\u0447\\u0438\\u0442, \\u043e\\u0434\\u043d\\u0430 \\u043a\\u043b\\u0430\\u0443\\u0437\\u0430. \\u041d\\u043e \\u043e\\u043d\\u0430 \\u043d\\u0435 \\u043d\\u0435\\u043f\\u0440\\u0435\\u0440\\u044b\\u0432\\u043d\\u0430. \\u0417\\u043d\\u0430\\u0447\\u0438\\u0442, \\u043b\\u0438\\u0431\\u043e \\u043c\\u044b \\u043e\\u0448\\u0438\\u0431\\u043b\\u0438\\u0441\\u044c \\u0432 \\u0430\\u043d\\u0430\\u043b\\u0438\\u0437\\u0435, \\u043b\\u0438\\u0431\\u043e \\u043d\\u0443\\u0436\\u043d\\u043e \\u0441\\u0447\\u0438\\u0442\\u0430\\u0442\\u044c, \\u0447\\u0442\\u043e \\\"\\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c\\\" \\u0438 \\\"\\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c\\\" - \\u044d\\u0442\\u043e \\u0434\\u0432\\u0435 \\u0440\\u0430\\u0437\\u043d\\u044b\\u0435 \\u043e\\u0441\\u043d\\u043e\\u0432\\u044b? \\u041d\\u043e \\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u0435 \\u043e\\u0434\\u043d\\u043e, \\u0442\\u0430\\u043a \\u0447\\u0442\\u043e \\u044d\\u0442\\u043e \\u043e\\u0434\\u043d\\u043e\\u0440\\u043e\\u0434\\u043d\\u044b\\u0435 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u044b\\u0435, \\u043e\\u0434\\u043d\\u0430 \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430.\\\\n\\\\n\\u0412\\u0437\\u0433\\u043b\\u044f\\u043d\\u0435\\u043c \\u043d\\u0430 \\u0441\\u0442\\u0440\\u0443\\u043a\\u0442\\u0443\\u0440\\u0443: \\\"\\u042f \\u0438 \\u0441\\u0430\\u043c\\u0430 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c, \\u0447\\u0442\\u043e \\u043e\\u043d\\u0430 \\u043c\\u0435\\u043d\\u044f \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u0443\\u0435\\u0442, \\u0438 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c \\u0441 \\u043d\\u0435\\u0439 \\u0445\\u043e\\u043b\\u043e\\u0434\\u043d\\u0435\\u0435\\\". \\u0417\\u0434\\u0435\\u0441\\u044c \\u0441\\u043e\\u044e\\u0437 \\\"\\u0438\\\" \\u0441\\u043e\\u0435\\u0434\\u0438\\u043d\\u044f\\u0435\\u0442 \\u043e\\u0434\\u043d\\u043e\\u0440\\u043e\\u0434\\u043d\\u044b\\u0435 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u044b\\u0435 \\\"\\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c\\\" \\u0438 \\\"\\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c\\\". \\u041c\\u0435\\u0436\\u0434\\u0443 \\u043d\\u0438\\u043c\\u0438 \\u0441\\u0442\\u043e\\u0438\\u0442 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435 \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0435, \\u043a\\u043e\\u0442\\u043e\\u0440\\u043e\\u0435 \\u044f\\u0432\\u043b\\u044f\\u0435\\u0442\\u0441\\u044f \\u0437\\u0430\\u0432\\u0438\\u0441\\u0438\\u043c\\u044b\\u043c \\u043e\\u0442 \\u043f\\u0435\\u0440\\u0432\\u043e\\u0433\\u043e \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u043e\\u0433\\u043e. \\u0412 \\u0440\\u0443\\u0441\\u0441\\u043a\\u043e\\u043c \\u044f\\u0437\\u044b\\u043a\\u0435 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435 \\u043c\\u043e\\u0436\\u0435\\u0442 \\u043d\\u0430\\u0445\\u043e\\u0434\\u0438\\u0442\\u044c\\u0441\\u044f \\u043c\\u0435\\u0436\\u0434\\u0443 \\u0447\\u0430\\u0441\\u0442\\u044f\\u043c\\u0438 \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0433\\u043e \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u044f, \\u043d\\u043e \\u043f\\u0440\\u0438 \\u044d\\u0442\\u043e\\u043c \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0435 \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0435 \\u0441\\u0447\\u0438\\u0442\\u0430\\u0435\\u0442\\u0441\\u044f \\u0435\\u0434\\u0438\\u043d\\u044b\\u043c, \\u0445\\u043e\\u0442\\u044f \\u0435\\u0433\\u043e \\u0447\\u0430\\u0441\\u0442\\u0438 \\u0440\\u0430\\u0437\\u043e\\u0440\\u0432\\u0430\\u043d\\u044b. \\u041f\\u0440\\u0438 \\u0432\\u044b\\u0434\\u0435\\u043b\\u0435\\u043d\\u0438\\u0438 \\u043a\\u043b\\u0430\\u0443\\u0437 \\u043e\\u0431\\u044b\\u0447\\u043d\\u043e \\u0431\\u0435\\u0440\\u0443\\u0442 \\u0433\\u043b\\u0430\\u0432\\u043d\\u0443\\u044e \\u0447\\u0430\\u0441\\u0442\\u044c \\u043a\\u0430\\u043a \\u0441\\u043e\\u0432\\u043e\\u043a\\u0443\\u043f\\u043d\\u043e\\u0441\\u0442\\u044c \\u0432\\u0441\\u0435\\u0445 \\u0435\\u0435 \\u0447\\u0430\\u0441\\u0442\\u0435\\u0439, \\u043d\\u043e \\u043a\\u0430\\u043a \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u0443 \\u044d\\u0442\\u043e \\u043d\\u0435\\u0432\\u043e\\u0437\\u043c\\u043e\\u0436\\u043d\\u043e. \\u0412 \\u043d\\u0435\\u043a\\u043e\\u0442\\u043e\\u0440\\u044b\\u0445 \\u0441\\u0438\\u0441\\u0442\\u0435\\u043c\\u0430\\u0445 \\u0441\\u0438\\u043d\\u0442\\u0430\\u043a\\u0441\\u0438\\u0447\\u0435\\u0441\\u043a\\u043e\\u0433\\u043e \\u0430\\u043d\\u0430\\u043b\\u0438\\u0437\\u0430 (\\u043d\\u0430\\u043f\\u0440\\u0438\\u043c\\u0435\\u0440, \\u0432 NLTK) \\u043f\\u0440\\u0438 \\u0442\\u0430\\u043a\\u043e\\u043c \\u0440\\u0430\\u0437\\u0431\\u043e\\u0440\\u0435 \\u0432\\u044b\\u0434\\u0435\\u043b\\u044f\\u044e\\u0442 \\u0442\\u0430\\u043a \\u043d\\u0430\\u0437\\u044b\\u0432\\u0430\\u0435\\u043c\\u044b\\u0435 \\\"split clauses\\\". \\u041d\\u043e \\u0432 \\u043d\\u0430\\u0448\\u0435\\u043c \\u0437\\u0430\\u0434\\u0430\\u043d\\u0438\\u0438, \\u0441\\u0443\\u0434\\u044f \\u043f\\u043e \\u043f\\u0440\\u0438\\u043c\\u0435\\u0440\\u0430\\u043c, \\u0432\\u0441\\u0435 \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b \\u0431\\u044b\\u043b\\u0438 \\u043d\\u0435\\u043f\\u0440\\u0435\\u0440\\u044b\\u0432\\u043d\\u044b\\u043c\\u0438. \\u0412 \\u043f\\u0440\\u0438\\u043c\\u0435\\u0440\\u0435 \\\"\\u0414\\u043e\\u0436\\u0434\\u044c \\u043a\\u043e\\u043d\\u0447\\u0438\\u043b\\u0441\\u044f, \\u0438 \\u043c\\u044b \\u0432\\u044b\\u0448\\u043b\\u0438 \\u043d\\u0430 \\u0443\\u043b\\u0438\\u0446\\u0443\\\" - \\u043e\\u0431\\u0435 \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b \\u043d\\u0435\\u043f\\u0440\\u0435\\u0440\\u044b\\u0432\\u043d\\u044b. \\\"\\u0421\\u043e\\u043b\\u043d\\u0446\\u0435 \\u0441\\u0435\\u043b\\u043e: \\u0441\\u0442\\u0430\\u043b\\u043e \\u043f\\u0440\\u043e\\u0445\\u043b\\u0430\\u0434\\u043d\\u043e\\\" - \\u0442\\u043e\\u0436\\u0435 \\u043d\\u0435\\u043f\\u0440\\u0435\\u0440\\u044b\\u0432\\u043d\\u044b. \\u041d\\u0435\\u0442 \\u043f\\u0440\\u0438\\u043c\\u0435\\u0440\\u0430 \\u0441 \\u0432\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0435\\u043c.\\\\n\\\\n\\u0412\\u043e\\u0437\\u043c\\u043e\\u0436\\u043d\\u043e, \\u0437\\u0434\\u0435\\u0441\\u044c \\u043d\\u0443\\u0436\\u043d\\u043e \\u0441\\u0447\\u0438\\u0442\\u0430\\u0442\\u044c, \\u0447\\u0442\\u043e \\\"\\u042f \\u0438 \\u0441\\u0430\\u043c\\u0430 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c\\\" - \\u044d\\u0442\\u043e \\u043e\\u0434\\u043d\\u0430 \\u043a\\u043b\\u0430\\u0443\\u0437\\u0430 (\\u0447\\u0430\\u0441\\u0442\\u044c \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439 \\u0434\\u043e \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0439), \\\"\\u0447\\u0442\\u043e \\u043e\\u043d\\u0430 \\u043c\\u0435\\u043d\\u044f \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u0443\\u0435\\u0442\\\" - \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u0430\\u044f, \\\"\\u0438 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c \\u0441 \\u043d\\u0435\\u0439 \\u0445\\u043e\\u043b\\u043e\\u0434\\u043d\\u0435\\u0435\\\" - \\u0432\\u0442\\u043e\\u0440\\u0430\\u044f \\u0447\\u0430\\u0441\\u0442\\u044c \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439? \\u041d\\u043e \\u0442\\u043e\\u0433\\u0434\\u0430 \\u044d\\u0442\\u043e \\u0434\\u0432\\u0435 \\u0440\\u0430\\u0437\\u043d\\u044b\\u0435 \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b, \\u0445\\u043e\\u0442\\u044f \\u0433\\u0440\\u0430\\u043c\\u043c\\u0430\\u0442\\u0438\\u0447\\u0435\\u0441\\u043a\\u0438 \\u043e\\u043d\\u0438 \\u043e\\u0442\\u043d\\u043e\\u0441\\u044f\\u0442\\u0441\\u044f \\u043a \\u043e\\u0434\\u043d\\u043e\\u0439 \\u043e\\u0441\\u043d\\u043e\\u0432\\u0435. \\u041d\\u043e \\u0435\\u0441\\u043b\\u0438 \\u043c\\u044b \\u0440\\u0430\\u0437\\u0434\\u0435\\u043b\\u0438\\u043c, \\u0442\\u043e \\u043f\\u043e\\u043b\\u0443\\u0447\\u0438\\u0442\\u0441\\u044f \\u0442\\u0440\\u0438 \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b: \\u043f\\u0435\\u0440\\u0432\\u0430\\u044f \\u0447\\u0430\\u0441\\u0442\\u044c \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439, \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u0430\\u044f, \\u0432\\u0442\\u043e\\u0440\\u0430\\u044f \\u0447\\u0430\\u0441\\u0442\\u044c \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439. \\u0410 \\u043f\\u043e\\u0442\\u043e\\u043c \\u0435\\u0449\\u0435 \\\"\\u043d\\u043e \\u043e\\u043d\\u0430 \\u043f\\u0440\\u043e\\u0434\\u043e\\u043b\\u0436\\u0430\\u0435\\u0442 \\u043c\\u0435\\u043d\\u044f \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u043e\\u0432\\u0430\\u0442\\u044c\\\". \\u0418\\u0442\\u043e\\u0433\\u043e 4 \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b. \\u041d\\u043e \\u043a\\u043e\\u043b\\u0438\\u0447\\u0435\\u0441\\u0442\\u0432\\u043e \\u0433\\u0440\\u0430\\u043c\\u043c\\u0430\\u0442\\u0438\\u0447\\u0435\\u0441\\u043a\\u0438\\u0445 \\u043e\\u0441\\u043d\\u043e\\u0432: \\u0432 \\u043f\\u0435\\u0440\\u0432\\u043e\\u0439 \\u0447\\u0430\\u0441\\u0442\\u0438 \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439 \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430 \\\"\\u042f \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c\\\" (\\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u0435 \\u0438 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u043e\\u0435), \\u0432\\u043e \\u0432\\u0442\\u043e\\u0440\\u043e\\u0439 \\u0447\\u0430\\u0441\\u0442\\u0438 \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439 \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430 \\\"\\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c\\\" (\\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u0435 \\u043e\\u043f\\u0443\\u0449\\u0435\\u043d\\u043e, \\u043d\\u043e \\u0442\\u043e \\u0436\\u0435 \\u042f), \\u044d\\u0442\\u043e \\u043e\\u0434\\u043d\\u0430 \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430? \\u041d\\u0435\\u0442, \\u044d\\u0442\\u043e \\u0434\\u0432\\u0430 \\u0440\\u0430\\u0437\\u043d\\u044b\\u0445 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u044b\\u0445, \\u043d\\u043e \\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u0435 \\u043e\\u0434\\u043d\\u043e - \\u044d\\u0442\\u043e \\u043e\\u0434\\u043d\\u043e\\u0440\\u043e\\u0434\\u043d\\u044b\\u0435 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u044b\\u0435, \\u043e\\u0434\\u043d\\u0430 \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430. \\u0415\\u0441\\u043b\\u0438 \\u043c\\u044b \\u0440\\u0430\\u0437\\u0440\\u044b\\u0432\\u0430\\u0435\\u043c, \\u0442\\u043e \\u043f\\u043e\\u043b\\u0443\\u0447\\u0430\\u0435\\u043c \\u0434\\u0432\\u0435 \\u043e\\u0441\\u043d\\u043e\\u0432\\u044b? \\u041d\\u043e \\u0444\\u043e\\u0440\\u043c\\u0430\\u043b\\u044c\\u043d\\u043e \\u0443 \\\"\\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c\\\" \\u0441\\u0432\\u043e\\u0435 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u043e\\u0435, \\u043d\\u043e \\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u0435 \\u043d\\u0435 \\u0432\\u044b\\u0440\\u0430\\u0436\\u0435\\u043d\\u043e, \\u0432\\u043e\\u0441\\u0441\\u0442\\u0430\\u043d\\u0430\\u0432\\u043b\\u0438\\u0432\\u0430\\u0435\\u0442\\u0441\\u044f. \\u0412 \\u0442\\u0430\\u043a\\u043e\\u043c \\u0441\\u043b\\u0443\\u0447\\u0430\\u0435 \\u043c\\u043e\\u0436\\u043d\\u043e \\u0441\\u0447\\u0438\\u0442\\u0430\\u0442\\u044c, \\u0447\\u0442\\u043e \\u044d\\u0442\\u043e \\u043e\\u0434\\u043d\\u0430 \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430, \\u043d\\u043e \\u0440\\u0430\\u0437\\u043e\\u0440\\u0432\\u0430\\u043d\\u043d\\u0430\\u044f. \\u041e\\u0434\\u043d\\u0430\\u043a\\u043e \\u043f\\u0440\\u0438 \\u043f\\u043e\\u0434\\u0441\\u0447\\u0435\\u0442\\u0435 \\u0433\\u0440\\u0430\\u043c\\u043c\\u0430\\u0442\\u0438\\u0447\\u0435\\u0441\\u043a\\u0438\\u0445 \\u043e\\u0441\\u043d\\u043e\\u0432 \\u043e\\u0431\\u044b\\u0447\\u043d\\u043e \\u0441\\u0447\\u0438\\u0442\\u0430\\u044e\\u0442 \\u043a\\u0430\\u0436\\u0434\\u0443\\u044e \\u043f\\u0440\\u0435\\u0434\\u0438\\u043a\\u0430\\u0442\\u0438\\u0432\\u043d\\u0443\\u044e \\u0435\\u0434\\u0438\\u043d\\u0438\\u0446\\u0443. \\u0412 \\\"\\u042f \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c \\u0438 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c\\\" - \\u044d\\u0442\\u043e \\u043e\\u0434\\u043d\\u0430 \\u043f\\u0440\\u0435\\u0434\\u0438\\u043a\\u0430\\u0442\\u0438\\u0432\\u043d\\u0430\\u044f \\u0435\\u0434\\u0438\\u043d\\u0438\\u0446\\u0430, \\u0442\\u0430\\u043a \\u043a\\u0430\\u043a \\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u0435 \\u043e\\u0431\\u0449\\u0435\\u0435. \\u041d\\u043e \\u0435\\u0441\\u043b\\u0438 \\u043c\\u044b \\u0432\\u044b\\u0434\\u0435\\u043b\\u044f\\u0435\\u043c \\u043a\\u0430\\u043a \\u043e\\u0442\\u0434\\u0435\\u043b\\u044c\\u043d\\u044b\\u0435 \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u0438, \\u0442\\u043e \\u043c\\u044b \\u0444\\u0430\\u043a\\u0442\\u0438\\u0447\\u0435\\u0441\\u043a\\u0438 \\u0441\\u043e\\u0437\\u0434\\u0430\\u0435\\u043c \\u0434\\u0432\\u0435 \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b \\u0438\\u0437 \\u043e\\u0434\\u043d\\u043e\\u0439, \\u0447\\u0442\\u043e \\u043d\\u0430\\u0440\\u0443\\u0448\\u0430\\u0435\\u0442 \\u043f\\u0440\\u0430\\u0432\\u0438\\u043b\\u043e \\u0440\\u0430\\u0432\\u0435\\u043d\\u0441\\u0442\\u0432\\u0430 \\u043a\\u043e\\u043b\\u0438\\u0447\\u0435\\u0441\\u0442\\u0432\\u0430 \\u043e\\u0441\\u043d\\u043e\\u0432.\\\\n\\\\n\\u0414\\u0430\\u0432\\u0430\\u0439\\u0442\\u0435 \\u043f\\u0435\\u0440\\u0435\\u0447\\u0438\\u0442\\u0430\\u0435\\u043c \\u043f\\u0440\\u0430\\u0432\\u0438\\u043b\\u0430: \\\"\\u041a\\u043e\\u043b\\u0438\\u0447\\u0435\\u0441\\u0442\\u0432\\u043e \\u043a\\u043b\\u0430\\u0443\\u0437 \\u0441\\u0442\\u0440\\u043e\\u0433\\u043e \\u0440\\u0430\\u0432\\u043d\\u043e \\u043a\\u043e\\u043b\\u0438\\u0447\\u0435\\u0441\\u0442\\u0432\\u0443 \\u0433\\u0440\\u0430\\u043c\\u043c\\u0430\\u0442\\u0438\\u0447\\u0435\\u0441\\u043a\\u0438\\u0445 \\u043e\\u0441\\u043d\\u043e\\u0432 \\u0432 \\u0438\\u0441\\u0445\\u043e\\u0434\\u043d\\u043e\\u043c \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0438.\\\" \\u0417\\u043d\\u0430\\u0447\\u0438\\u0442, \\u043c\\u044b \\u0434\\u043e\\u043b\\u0436\\u043d\\u044b \\u043e\\u043f\\u0440\\u0435\\u0434\\u0435\\u043b\\u0438\\u0442\\u044c \\u043a\\u043e\\u043b\\u0438\\u0447\\u0435\\u0441\\u0442\\u0432\\u043e \\u0433\\u0440\\u0430\\u043c\\u043c\\u0430\\u0442\\u0438\\u0447\\u0435\\u0441\\u043a\\u0438\\u0445 \\u043e\\u0441\\u043d\\u043e\\u0432. \\u0421\\u043a\\u043e\\u043b\\u044c\\u043a\\u043e \\u0438\\u0445 \\u0432 \\u043d\\u0430\\u0448\\u0435\\u043c \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0438?\\\\n\\\\n\\u041f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0435: \\\"\\u042f \\u0438 \\u0441\\u0430\\u043c\\u0430 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c, \\u0447\\u0442\\u043e \\u043e\\u043d\\u0430 \\u043c\\u0435\\u043d\\u044f \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u0443\\u0435\\u0442, \\u0438 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c \\u0441 \\u043d\\u0435\\u0439 \\u0445\\u043e\\u043b\\u043e\\u0434\\u043d\\u0435\\u0435, \\u043d\\u043e \\u043e\\u043d\\u0430 \\u043f\\u0440\\u043e\\u0434\\u043e\\u043b\\u0436\\u0430\\u0435\\u0442 \\u043c\\u0435\\u043d\\u044f \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u043e\\u0432\\u0430\\u0442\\u044c.\\\"\\\\n\\\\n\\u0413\\u0440\\u0430\\u043c\\u043c\\u0430\\u0442\\u0438\\u0447\\u0435\\u0441\\u043a\\u0438\\u0435 \\u043e\\u0441\\u043d\\u043e\\u0432\\u044b:\\\\n1. \\\"\\u042f \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c\\\" - \\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u0435 \\u042f, \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u043e\\u0435 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c (\\u0441\\u043e\\u0441\\u0442\\u0430\\u0432\\u043d\\u043e\\u0435 \\u0433\\u043b\\u0430\\u0433\\u043e\\u043b\\u044c\\u043d\\u043e\\u0435). \\u042d\\u0442\\u043e \\u043e\\u0434\\u043d\\u0430 \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430.\\\\n2. \\\"\\u043e\\u043d\\u0430 \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u0443\\u0435\\u0442\\\" - \\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u0435 \\u043e\\u043d\\u0430, \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u043e\\u0435 \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u0443\\u0435\\u0442. \\u0412\\u0442\\u043e\\u0440\\u0430\\u044f \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430.\\\\n3. \\\"\\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c\\\" - \\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u0435? \\u041e\\u043f\\u0443\\u0449\\u0435\\u043d\\u043e, \\u043d\\u043e \\u043f\\u043e\\u0434\\u0440\\u0430\\u0437\\u0443\\u043c\\u0435\\u0432\\u0430\\u0435\\u0442\\u0441\\u044f \\u042f. \\u042d\\u0442\\u043e \\u0442\\u0440\\u0435\\u0442\\u044c\\u044f \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430? \\u041d\\u043e \\\"\\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c\\\" - \\u044d\\u0442\\u043e \\u0432\\u0442\\u043e\\u0440\\u043e\\u0435 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u043e\\u0435 \\u043f\\u0440\\u0438 \\u0442\\u043e\\u043c \\u0436\\u0435 \\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u043c. \\u0412 \\u0440\\u0443\\u0441\\u0441\\u043a\\u043e\\u043c \\u044f\\u0437\\u044b\\u043a\\u0435 \\u043e\\u0434\\u043d\\u043e\\u0440\\u043e\\u0434\\u043d\\u044b\\u0435 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u044b\\u0435 \\u043d\\u0435 \\u043e\\u0431\\u0440\\u0430\\u0437\\u0443\\u044e\\u0442 \\u043e\\u0442\\u0434\\u0435\\u043b\\u044c\\u043d\\u043e\\u0439 \\u0433\\u0440\\u0430\\u043c\\u043c\\u0430\\u0442\\u0438\\u0447\\u0435\\u0441\\u043a\\u043e\\u0439 \\u043e\\u0441\\u043d\\u043e\\u0432\\u044b, \\u0442\\u0430\\u043a \\u043a\\u0430\\u043a \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430 - \\u044d\\u0442\\u043e \\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u0435 + \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u043e\\u0435. \\u0415\\u0441\\u043b\\u0438 \\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u0435 \\u043e\\u0434\\u043d\\u043e, \\u0430 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u044b\\u0445 \\u043d\\u0435\\u0441\\u043a\\u043e\\u043b\\u044c\\u043a\\u043e, \\u0442\\u043e \\u044d\\u0442\\u043e \\u043e\\u0434\\u043d\\u0430 \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430 \\u0441 \\u043d\\u0435\\u0441\\u043a\\u043e\\u043b\\u044c\\u043a\\u0438\\u043c\\u0438 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u044b\\u043c\\u0438. \\u0422\\u0430\\u043a\\u0438\\u043c \\u043e\\u0431\\u0440\\u0430\\u0437\\u043e\\u043c, \\\"\\u042f \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c \\u0438 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c\\\" - \\u043e\\u0434\\u043d\\u0430 \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430. \\u041d\\u043e \\u0432 \\u043d\\u0430\\u0448\\u0435\\u043c \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0438 \\u043c\\u0435\\u0436\\u0434\\u0443 \\u043d\\u0438\\u043c\\u0438 \\u0432\\u0441\\u0442\\u0430\\u0432\\u043b\\u0435\\u043d\\u043e \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435, \\u043d\\u043e \\u044d\\u0442\\u043e \\u043d\\u0435 \\u043c\\u0435\\u043d\\u044f\\u0435\\u0442 \\u0442\\u043e\\u0433\\u043e, \\u0447\\u0442\\u043e \\u044d\\u0442\\u043e \\u043e\\u0434\\u043d\\u0430 \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430. \\u0421\\u043b\\u0435\\u0434\\u043e\\u0432\\u0430\\u0442\\u0435\\u043b\\u044c\\u043d\\u043e, \\u0442\\u0440\\u0435\\u0442\\u044c\\u044f \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430 - \\\"\\u043e\\u043d\\u0430 \\u043f\\u0440\\u043e\\u0434\\u043e\\u043b\\u0436\\u0430\\u0435\\u0442 \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u043e\\u0432\\u0430\\u0442\\u044c\\\" (\\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u0435 \\u043e\\u043d\\u0430, \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u043e\\u0435 \\u043f\\u0440\\u043e\\u0434\\u043e\\u043b\\u0436\\u0430\\u0435\\u0442 \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u043e\\u0432\\u0430\\u0442\\u044c). \\u0418\\u0442\\u043e\\u0433\\u043e: \\u0434\\u0432\\u0435 \\u043e\\u0441\\u043d\\u043e\\u0432\\u044b? \\u041d\\u0435\\u0442, \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u0430\\u044f \\\"\\u043e\\u043d\\u0430 \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u0443\\u0435\\u0442\\\" - \\u044d\\u0442\\u043e \\u0432\\u0442\\u043e\\u0440\\u0430\\u044f \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430. \\u0418 \\u0442\\u0440\\u0435\\u0442\\u044c\\u044f - \\\"\\u043e\\u043d\\u0430 \\u043f\\u0440\\u043e\\u0434\\u043e\\u043b\\u0436\\u0430\\u0435\\u0442 \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u043e\\u0432\\u0430\\u0442\\u044c\\\". \\u041d\\u043e \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u0447\\u0430\\u0441\\u0442\\u044c \\u0441 \\u043e\\u0434\\u043d\\u043e\\u0440\\u043e\\u0434\\u043d\\u044b\\u043c\\u0438 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u044b\\u043c\\u0438 - \\u044d\\u0442\\u043e \\u043e\\u0434\\u043d\\u0430 \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430. \\u0412\\u0441\\u0435\\u0433\\u043e \\u0442\\u0440\\u0438 \\u043e\\u0441\\u043d\\u043e\\u0432\\u044b.\\\\n\\\\n\\u041d\\u043e \\u0442\\u043e\\u0433\\u0434\\u0430 \\u043a\\u0430\\u043a \\u0431\\u044b\\u0442\\u044c \\u0441 \\u0440\\u0430\\u0437\\u0440\\u044b\\u0432\\u043e\\u043c? \\u041f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u0430\\u044f \\u0447\\u0430\\u0441\\u0442\\u044c \\u0432\\u043b\\u043e\\u0436\\u0435\\u043d\\u0430 \\u0432 \\u0433\\u043b\\u0430\\u0432\\u043d\\u0443\\u044e. \\u0413\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u043e\\u0441\\u043d\\u043e\\u0432\\u0430 \\u043f\\u0440\\u0435\\u0434\\u0441\\u0442\\u0430\\u0432\\u043b\\u0435\\u043d\\u0430 \\u0434\\u0432\\u0443\\u043c\\u044f \\u043e\\u0442\\u0440\\u0435\\u0437\\u043a\\u0430\\u043c\\u0438: \\\"\\u042f \\u0438 \\u0441\\u0430\\u043c\\u0430 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c\\\" \\u0438 \\\"\\u0438 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c \\u0441 \\u043d\\u0435\\u0439 \\u0445\\u043e\\u043b\\u043e\\u0434\\u043d\\u0435\\u0435\\\". \\u042d\\u0442\\u0438 \\u0434\\u0432\\u0430 \\u043e\\u0442\\u0440\\u0435\\u0437\\u043a\\u0430 \\u0432\\u043c\\u0435\\u0441\\u0442\\u0435 \\u043e\\u0431\\u0440\\u0430\\u0437\\u0443\\u044e\\u0442 \\u043e\\u0434\\u043d\\u0443 \\u043a\\u043b\\u0430\\u0443\\u0437\\u0443. \\u041d\\u043e \\u043f\\u043e\\u0441\\u043a\\u043e\\u043b\\u044c\\u043a\\u0443 \\u043e\\u043d\\u0438 \\u043d\\u0435 \\u043d\\u0435\\u043f\\u0440\\u0435\\u0440\\u044b\\u0432\\u043d\\u044b, \\u043c\\u044b \\u043d\\u0435 \\u043c\\u043e\\u0436\\u0435\\u043c \\u0432\\u0435\\u0440\\u043d\\u0443\\u0442\\u044c \\u0438\\u0445 \\u043a\\u0430\\u043a \\u043e\\u0434\\u043d\\u0443 \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u0443. \\u0417\\u043d\\u0430\\u0447\\u0438\\u0442, \\u043d\\u0443\\u0436\\u043d\\u043e \\u043b\\u0438\\u0431\\u043e \\u0432\\u0435\\u0440\\u043d\\u0443\\u0442\\u044c \\u0434\\u0432\\u0435 \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u0438, \\u043a\\u043e\\u0442\\u043e\\u0440\\u044b\\u0435 \\u0432\\u043c\\u0435\\u0441\\u0442\\u0435 \\u0441\\u043e\\u0441\\u0442\\u0430\\u0432\\u043b\\u044f\\u044e\\u0442 \\u0433\\u043b\\u0430\\u0432\\u043d\\u0443\\u044e \\u043a\\u043b\\u0430\\u0443\\u0437\\u0443, \\u043d\\u043e \\u0442\\u043e\\u0433\\u0434\\u0430 \\u044d\\u0442\\u043e \\u0431\\u0443\\u0434\\u0435\\u0442 \\u0434\\u0432\\u0435 \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b, \\u0447\\u0442\\u043e \\u043d\\u0435\\u0432\\u0435\\u0440\\u043d\\u043e \\u043f\\u043e \\u043a\\u043e\\u043b\\u0438\\u0447\\u0435\\u0441\\u0442\\u0432\\u0443. \\u041b\\u0438\\u0431\\u043e \\u0441\\u0447\\u0438\\u0442\\u0430\\u0442\\u044c, \\u0447\\u0442\\u043e \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u043a\\u043b\\u0430\\u0443\\u0437\\u0430 - \\u044d\\u0442\\u043e \\u0432\\u0435\\u0441\\u044c \\u043e\\u0442\\u0440\\u0435\\u0437\\u043e\\u043a \\u043e\\u0442 \\\"\\u042f\\\" \\u0434\\u043e \\\"\\u0445\\u043e\\u043b\\u043e\\u0434\\u043d\\u0435\\u0435\\\", \\u0432\\u043a\\u043b\\u044e\\u0447\\u0430\\u044f \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u0443\\u044e? \\u041d\\u043e \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u0430\\u044f \\u0432\\u0445\\u043e\\u0434\\u0438\\u0442 \\u0432 \\u0441\\u043e\\u0441\\u0442\\u0430\\u0432 \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439? \\u041d\\u0435\\u0442, \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u0430\\u044f - \\u043e\\u0442\\u0434\\u0435\\u043b\\u044c\\u043d\\u0430\\u044f \\u043a\\u043b\\u0430\\u0443\\u0437\\u0430. \\u041e\\u043d\\u0430 \\u043d\\u0435 \\u044f\\u0432\\u043b\\u044f\\u0435\\u0442\\u0441\\u044f \\u0447\\u0430\\u0441\\u0442\\u044c\\u044e \\u0433\\u043b\\u0430\\u0432\\u043d\\u043e\\u0439 \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b, \\u043e\\u043d\\u0430 \\u0432\\u043b\\u043e\\u0436\\u0435\\u043d\\u0430. \\u0412 \\u0441\\u0438\\u043d\\u0442\\u0430\\u043a\\u0441\\u0438\\u0441\\u0435 \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u043a\\u043b\\u0430\\u0443\\u0437\\u0430 - \\u044d\\u0442\\u043e \\u0442\\u043e, \\u0447\\u0442\\u043e \\u043e\\u0441\\u0442\\u0430\\u0435\\u0442\\u0441\\u044f \\u043f\\u043e\\u0441\\u043b\\u0435 \\u0443\\u0434\\u0430\\u043b\\u0435\\u043d\\u0438\\u044f \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0439. \\u0422\\u0430\\u043a \\u0447\\u0442\\u043e \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f - \\u044d\\u0442\\u043e \\\"\\u042f \\u0438 \\u0441\\u0430\\u043c\\u0430 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c ... \\u0438 \\u043d\\ufffd\\ufffd\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c \\u0441 \\u043d\\u0435\\u0439 \\u0445\\u043e\\u043b\\u043e\\u0434\\u043d\\u0435\\u0435\\\", \\u043d\\u043e \\u0441 \\u043f\\u0440\\u043e\\u0431\\u0435\\u043b\\u0430\\u043c\\u0438.\\\\n\\\\n\\u0412 \\u0442\\u0430\\u043a\\u0438\\u0445 \\u0441\\u043b\\u0443\\u0447\\u0430\\u044f\\u0445 \\u0432 \\u043b\\u0438\\u043d\\u0433\\u0432\\u0438\\u0441\\u0442\\u0438\\u043a\\u0435 \\u0433\\u043e\\u0432\\u043e\\u0440\\u044f\\u0442 \\u043e \\\"\\u043f\\u0440\\u0435\\u0440\\u044b\\u0432\\u0438\\u0441\\u0442\\u043e\\u0439\\\" \\u043a\\u043b\\u0430\\u0443\\u0437\\u0435. \\u041f\\u0440\\u0438 \\u0430\\u0432\\u0442\\u043e\\u043c\\u0430\\u0442\\u0438\\u0447\\u0435\\u0441\\u043a\\u043e\\u043c \\u0430\\u043d\\u0430\\u043b\\u0438\\u0437\\u0435 \\u0438\\u043d\\u043e\\u0433\\u0434\\u0430 \\u0432\\u044b\\u0434\\u0435\\u043b\\u044f\\u044e\\u0442 \\\"\\u043b\\u0435\\u0432\\u0443\\u044e \\u0447\\u0430\\u0441\\u0442\\u044c\\\" \\u0438 \\\"\\u043f\\u0440\\u0430\\u0432\\u0443\\u044e \\u0447\\u0430\\u0441\\u0442\\u044c\\\" \\u043a\\u0430\\u043a \\u043e\\u0442\\u0434\\u0435\\u043b\\u044c\\u043d\\u044b\\u0435 \\u043a\\u043b\\u0430\\u0443\\u0437\\u044b, \\u043d\\u043e \\u044d\\u0442\\u043e \\u043d\\u0435\\u043f\\u0440\\u0430\\u0432\\u0438\\u043b\\u044c\\u043d\\u043e. \\u0412\\u043e\\u0437\\u043c\\u043e\\u0436\\u043d\\u043e, \\u0432 \\u0434\\u0430\\u043d\\u043d\\u043e\\u043c \\u0437\\u0430\\u0434\\u0430\\u043d\\u0438\\u0438 \\u043f\\u043e\\u0434\\u0440\\u0430\\u0437\\u0443\\u043c\\u0435\\u0432\\u0430\\u0435\\u0442\\u0441\\u044f, \\u0447\\u0442\\u043e \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0435 \\u0442\\u0430\\u043a \\u043f\\u043e\\u0441\\u0442\\u0440\\u043e\\u0435\\u043d\\u043e, \\u0447\\u0442\\u043e \\u0433\\u043b\\u0430\\u0432\\u