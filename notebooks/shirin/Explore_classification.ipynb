441\\u044f \\u043d\\u0435\\u043f\\u043e\\u043b\\u043d\\u043e\\u0439, \\u043d\\u043e \\u0432\\u0441\\u0435 \\u0440\\u0430\\u0432\\u043d\\u043e \\u0438\\u043c\\u0435\\u0435\\u0442 \\u0433\\u0440\\u0430\\u043c\\u043c\\u0430\\u0442\\u0438\\u0447\\u0435\\u0441\\u043a\\u0443\\u044e \\u043e\\u0441\\u043d\\u043e\\u0432\\u0443 (\\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u043e\\u0435). \\u0422\\u0430\\u043a \\u0447\\u0442\\u043e \\u043c\\u043e\\u0436\\u043d\\u043e \\u0441\\u0447\\u0438\\u0442\\u0430\\u0442\\u044c, \\u0447\\u0442\\u043e A, B, C, D - \\u0447\\u0435\\u0442\\u044b\\u0440\\u0435 \\u043e\\u0441\\u043d\\u043e\\u0432\\u044b. \\u041e\\u0434\\u043d\\u0430\\u043a\\u043e \\u043f\\u0440\\u0430\\u0432\\u0438\\u043b\\u043e \\\"\\u041d\\u0435 \\u0440\\u0430\\u0437\\u0440\\u044b\\u0432\\u0430\\u0439: \\u043e\\u0434\\u043d\\u043e\\u0440\\u043e\\u0434\\u043d\\u044b\\u0435 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u044b\\u0435\\\" \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442, \\u0447\\u0442\\u043e \\u0438\\u0445 \\u043d\\u0435 \\u043d\\u0443\\u0436\\u043d\\u043e \\u0440\\u0430\\u0437\\u0440\\u044b\\u0432\\u0430\\u0442\\u044c. \\u0422\\u043e \\u0435\\u0441\\u0442\\u044c \\u043c\\u044b \\u0434\\u043e\\u043b\\u0436\\u043d\\u044b \\u0441\\u0447\\u0438\\u0442\\u0430\\u0442\\u044c \\u0438\\u0445 \\u043e\\u0434\\u043d\\u043e\\u0439 \\u043a\\u043b\\u0430\\u0443\\u0437\\u043e\\u0439, \\u043d\\u043e \\u043a\\u0430\\u043a \\u0442\\u043e\\u0433\\u0434\\u0430 \\u0431\\u044b\\u0442\\u044c \\u0441 \\u043f\\u043e\\u0434\\u0441\\u0442\\u0440\\u043e\\u043a\\u043e\\u0439?\\\\n\\\\n\\u041f\\u043e\\u043f\\u0440\\u043e\\u0431\\u0443\\u0435\\u043c \\u0434\\u0440\\u0443\\u0433\\u043e\\u0439 \\u043f\\u043e\\u0434\\u0445\\u043e\\u0434: \\u043c\\u043e\\u0436\\u0435\\u0442 \\u0431\\u044b\\u0442\\u044c, \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435 \\\"\\u0447\\u0442\\u043e \\u043e\\u043d\\u0430 \\u043c\\u0435\\u043d\\u044f \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u0443\\u0435\\u0442\\\" \\u044f\\u0432\\u043b\\u044f\\u0435\\u0442\\u0441\\u044f \\u043d\\u0435 \\u0432\\u0441\\u0442\\u0430\\u0432\\u043a\\u043e\\u0439, \\u0430 \\u0441\\u0442\\u043e\\u0438\\u0442 \\u043f\\u043e\\u0441\\u043b\\u0435 \\u043f\\u0435\\u0440\\u0432\\u043e\\u0433\\u043e \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u043e\\u0433\\u043e, \\u0430 \\u0437\\u0430\\u0442\\u0435\\u043c \\u0438\\u0434\\u0435\\u0442 \\u0432\\u0442\\u043e\\u0440\\u043e\\u0435 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u043e\\u0435, \\u0441\\u043e\\u0435\\u0434\\u0438\\u043d\\u0435\\u043d\\u043d\\u043e\\u0435 \\u0441\\u043e\\u044e\\u0437\\u043e\\u043c \\\"\\u0438\\\". \\u0412 \\u0442\\u0430\\u043a\\u043e\\u043c \\u0441\\u043b\\u0443\\u0447\\u0430\\u0435 \\u0433\\u043b\\u0430\\u0432\\u043d\\u0430\\u044f \\u0447\\u0430\\u0441\\u0442\\u044c \\u043d\\u0435 \\u0440\\u0430\\u0437\\u0440\\u044b\\u0432\\u0430\\u0435\\u0442\\u0441\\u044f, \\u0430 \\u043f\\u0440\\u043e\\u0441\\u0442\\u043e \\u043f\\u043e\\u0441\\u043b\\u0435 \\u043f\\u0435\\u0440\\u0432\\u043e\\u0433\\u043e \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u043e\\u0433\\u043e \\u0438\\u0434\\u0435\\u0442 \\u043f\\u0440\\u0438\\u0434\\u0430\\u0442\\u043e\\u0447\\u043d\\u043e\\u0435, \\u0437\\u0430\\u0442\\u0435\\u043c \\u0437\\u0430\\u043f\\u044f\\u0442\\u0430\\u044f \\u0438 \\u0441\\u043e\\u044e\\u0437 \\\"\\u0438\\\" \\u043d\\u0430\\u0447\\u0438\\u043d\\u0430\\u0435\\u0442 \\u0432\\u0442\\u043e\\u0440\\u043e\\u0435 \\u0441\\u043a\\u0430\\u0437\\u0443\\u0435\\u043c\\u043e\\u0435. \\u0422\\u043e \\u0435\\u0441\\u0442\\u044c \\u043f\\u043e\\u0441\\u043b\\u0435\\u0434\\u043e\\u0432\\u0430\\u0442\\u0435\\u043b\\u044c\\u043d\\u043e\\u0441\\u0442\\u044c: [\\u042f \\u0438 \\u0441\\u0430\\u043c\\u0430 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c] [\\u0447\\u0442\\u043e \\u043e\\u043d\\u0430 \\u043c\\u0435\\u043d\\u044f \\u