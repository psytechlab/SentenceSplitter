\\u0414\\u0430\\u0432\\u0430\\u0439\\u0442\\u0435 \\u043f\\u0440\\u043e\\u0432\\u0435\\u0440\\u0438\\u043c: \\u0432 \\u043f\\u0440\\u0435\\u0434\\u043b\\u043e\\u0436\\u0435\\u043d\\u0438\\u0438 \\\"\\u042f \\u0438 \\u0441\\u0430\\u043c\\u0430 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c, \\u0447\\u0442\\u043e \\u043e\\u043d\\u0430 \\u043c\\u0435\\u043d\\u044f \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u0443\\u0435\\u0442, \\u0438 \\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c \\u0441 \\u043d\\u0435\\u0439 \\u0445\\u043e\\u043b\\u043e\\u0434\\u043d\\u0435\\u0435, \\u043d\\u043e \\u043e\\u043d\\u0430 \\u043f\\u0440\\u043e\\u0434\\u043e\\u043b\\u0436\\u0430\\u0435\\u0442 \\u043c\\u0435\\u043d\\u044f \\u0438\\u0441\\u043f\\u043e\\u043b\\u044c\\u0437\\u043e\\u0432\\u0430\\u0442\\u044c.\\\" \\u041c\\u043e\\u0436\\u043d\\u043e \\u043b\\u0438 \\u0441\\u0447\\u0438\\u0442\\u0430\\u0442\\u044c, \\u0447\\u0442\\u043e \\\"\\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0447\\u0443\\u0432\\u0441\\u0442\\u0432\\u043e\\u0432\\u0430\\u0442\\u044c\\\" \\u0438 \\\"\\u043d\\u0430\\u0447\\u0430\\u043b\\u0430 \\u0433\\u043e\\u0432\\u043e\\u0440\\u0438\\u0442\\u044c\\\" - \\u044d\\u0442\\u043e \\u0440\\u0430\\u0437\\u043d\\u044b\\u0435 \\u0433\\u0440\\u0430\\u043c\\u043c\\u0430\\u0442\\u0438\\u0447\\u0435\\u0441\\u043a\\u0438\\u0435 \\u043e\\u0441\\u043d\\u043e\\u0432\\u044b? \\u041e\\u043d\\u0438 \\u0438\\u043c\\u0435\\u044e\\u0442 \\u043e\\u0434\\u043d\\u043e \\u043f\\u043e\\u0434\\u043b\\u0435\\u0436\\u0430\\u0449\\u0435\\u0435, \\u043d\\u043e \\u0432 \\u043a\\u0430\\u0436\\u0434\\u043e\\u0439 \\u0435\\u0441\\u0442\\u044c \\u0441\\u0432\\u043e\\u0439 \\u0433\\u043b\\u0430\\u0433\\u043e\\u043b. \\u0412 \\u043d\\u0435\\u043a\\u043e\\u0442\\u043e\\u0440\\u044b\\u0445 \\u0433\\u0440\\u0430\\u043c\\u043c\\u0430\\u0442\\u0438\\u043a\\u0430\\u0445 \\u043a\\u0